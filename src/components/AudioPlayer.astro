---
// src/components/AudioPlayer.astro
const { tracks } = Astro.props;

// 🚀 SMART MAPPING: Sinkronisasi data YouTube Music dari skema Sanity
const sanityTracks = tracks?.map((track: any) => ({
  trackTitle: track.trackTitle || "Untitled Track",
  artist: track.artist || "Unknown Artist",
  youtubeUrl: track.youtubeUrl || ""
})).filter((track: any) => track.youtubeUrl);

const finalTracks = sanityTracks && sanityTracks.length > 0 ? sanityTracks : [
  { trackTitle: "Every Summertime", artist: "NIKI", youtubeUrl: "https://music.youtube.com/watch?v=J7p4bzqlvCw" },
  { trackTitle: "Cyber Ambient Drive (Fallback)", artist: "Lofi Core", youtubeUrl: "https://music.youtube.com/watch?v=J7p4bzqlvCw" }
];
---

<div id="cyber-audio-widget" class="relative w-full p-5 rounded-2xl bg-white/10 dark:bg-zinc-900/15 border-zinc-200/80 dark:border-zinc-900/60 overflow-hidden flex flex-col justify-between shadow-sm group/audio min-h-[130px] transition-all duration-300 opacity-0 transform translate-y-8">
  
  <div class="flex items-center justify-between gap-4 z-10">
    <div class="flex flex-col overflow-hidden pointer-events-none">
      <span class="text-[10px] font-mono font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-0.5">// YouTube Audio Stream Node</span>
      <div class="relative overflow-hidden z-10">
        <span id="player-track-title" class="text-sm font-bold text-zinc-800 dark:text-zinc-100 truncate font-mono block">Loading Track...</span>
        <span id="player-track-artist" class="text-xs text-zinc-400 dark:text-zinc-500 font-medium font-mono block truncate">Please wait</span>
      </div>
    </div>
    
    <div id="audio-wave-bars" class="flex items-end gap-[2px] h-3.5 shrink-0 transition-opacity opacity-40">
      <div class="w-[2px] bg-emerald-500 h-full origin-bottom rounded-full wave-bar"></div>
      <div class="w-[2px] bg-emerald-500 h-2/3 origin-bottom rounded-full wave-bar"></div>
      <div class="w-[2px] bg-emerald-500 h-4/5 origin-bottom rounded-full wave-bar"></div>
    </div>
  </div>

  <div class="flex items-center justify-between gap-2 border-t border-zinc-200/60 dark:border-zinc-900/50 pt-3 mt-2 z-10">
    <div class="flex items-center gap-1.5">
      <button id="audio-prev-track" class="p-2 border border-zinc-200 dark:border-zinc-800 hover:border-emerald-500/40 text-zinc-400 hover:text-emerald-500 rounded-xl transition-all cursor-pointer bg-white dark:bg-zinc-950 shadow-sm email-magnetic-btn" aria-label="Previous Track">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.5 12l8.5 6V6l-8.5 6zm-9 6h2V6h-2v12z"/></svg>
      </button>

      <button id="audio-play-toggle" class="p-2 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 rounded-xl transition-all cursor-pointer shadow-sm shadow-emerald-500/10 email-magnetic-btn" aria-label="Play/Pause">
        <svg id="play-svg-icon" class="w-3.5 h-3.5 block" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="pause-svg-icon" class="w-3.5 h-3.5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>

      <button id="audio-next-track" class="p-2 border border-zinc-200 dark:border-zinc-800 hover:border-emerald-500/40 text-zinc-400 hover:text-emerald-500 rounded-xl transition-all cursor-pointer bg-white dark:bg-zinc-950 shadow-sm email-magnetic-btn" aria-label="Next Track">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
      </button>
    </div>

    <div class="relative inline-block text-left">
      <select id="audio-track-selector" class="block w-full max-w-[130px] px-2 py-1.5 rounded-lg text-[10px] font-mono font-bold bg-zinc-100 dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 border border-zinc-200 dark:border-zinc-800 focus:outline-none focus:border-emerald-500/40 cursor-pointer">
        {finalTracks.map((track, idx) => (
          <option value={idx} data-url={track.youtubeUrl} data-title={track.trackTitle} data-artist={track.artist}>
            {track.trackTitle}
          </option>
        ))}
      </select>
    </div>
  </div>
</div>

<style>
  @keyframes dance-wave {
    0% { transform: scaleY(0.3); }
    50% { transform: scaleY(1); }
    100% { transform: scaleY(0.3); }
  }
  .animate-wave-bar .wave-bar:nth-child(1) { animation: dance-wave 0.6s ease-in-out infinite alternate; }
  .animate-wave-bar .wave-bar:nth-child(2) { animation: dance-wave 0.4s ease-in-out infinite alternate 0.1s; }
  .animate-wave-bar .wave-bar:nth-child(3) { animation: dance-wave 0.8s ease-in-out infinite alternate 0.2s; }
</style>

<script>
  import { gsap } from 'gsap';

  function extractYouTubeId(url: string) {
    if (!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
  }

  // 🌟 1. SETUP ENGINE CORE GLOBAL (Hanya dibuat 1 kali seumur hidup aplikasi)
  if (!window.CyberAudioCore) {
    window.CyberAudioCore = {
      ytPlayer: null,
      tracksData: [],
      currentTrackIndex: 0,
      isPlaying: false,
      isYTReady: false,

      init() {
        // KUNCI EMAS: Membuat wadah render iFrame di luar <body> (Menempel pada <html>)
        let holder = document.getElementById('global-yt-persistent-holder');
        if (!holder) {
          holder = document.createElement('div');
          holder.id = 'global-yt-persistent-holder';
          holder.style.position = 'absolute';
          holder.style.width = '1px';
          holder.style.height = '1px';
          holder.style.opacity = '0';
          holder.style.overflow = 'hidden';
          holder.innerHTML = '<div id="yt-persistent-actual-node"></div>';
          document.documentElement.appendChild(holder); // Amankan di level root html
        }

        if (!window.YT) {
          const tag = document.createElement('script');
          tag.src = "https://www.youtube.com/iframe_api";
          const firstScriptTag = document.getElementsByTagName('script')[0];
          firstScriptTag.parentNode?.insertBefore(tag, firstScriptTag);
          window.onYouTubeIframeAPIReady = () => this.buildPlayerInstance();
        } else {
          this.buildPlayerInstance();
        }
      },

      buildPlayerInstance() {
        if (this.ytPlayer) return;
        this.ytPlayer = new window.YT.Player('yt-persistent-actual-node', {
          height: '1', width: '1',
          videoId: this.tracksData[this.currentTrackIndex]?.id || '',
          playerVars: { 'autoplay': 0, 'controls': 0, 'disablekb': 1, 'rel': 0 },
          events: {
            'onReady': (event: any) => {
              this.isYTReady = true;
              const triggerInitialPlay = () => {
                if (!this.isPlaying) event.target.playVideo();
                document.removeEventListener('click', triggerInitialPlay);
              };
              document.addEventListener('click', triggerInitialPlay);
            },
            'onStateChange': (event: any) => {
              if (event.data === 1) {
                this.isPlaying = true;
              } else if (event.data === 0) {
                let nextIndex = this.currentTrackIndex + 1;
                if (nextIndex >= this.tracksData.length) nextIndex = 0;
                this.switchTrack(nextIndex);
              } else {
                this.isPlaying = false;
              }
              // Kirim sinyal broadcast global ke seluruh halaman agar UI tersinkronisasi
              window.dispatchEvent(new CustomEvent('cyber-audio-sync-signal'));
            }
          }
        });
      },

      play() {
        if (this.ytPlayer && this.isYTReady) this.ytPlayer.playVideo();
      },
      pause() {
        if (this.ytPlayer && this.isYTReady) this.ytPlayer.pauseVideo();
      },
      switchTrack(index: number) {
        this.currentTrackIndex = index;
        if (this.ytPlayer && this.isYTReady) {
          this.ytPlayer.loadVideoById(this.tracksData[index].id);
        }
        window.dispatchEvent(new CustomEvent('cyber-audio-sync-signal'));
      }
    };
  }

  // 🌟 2. UI CONNECTOR ENGINE (Berjalan otomatis setiap kali halaman ditukar/di-render ulang)
  function syncUIWithCoreEngine() {
    const core = window.CyberAudioCore;
    const selector = document.getElementById('audio-track-selector') as HTMLSelectElement;
    const playBtn = document.getElementById('audio-play-toggle');
    const prevBtn = document.getElementById('audio-prev-track');
    const nextBtn = document.getElementById('audio-next-track');
    const titleEl = document.getElementById('player-track-title');
    const artistEl = document.getElementById('player-track-artist');
    const waveContainer = document.getElementById('audio-wave-bars');
    const playIcon = document.getElementById('play-svg-icon');
    const pauseIcon = document.getElementById('pause-svg-icon');
    const widget = document.getElementById('cyber-audio-widget');

    if (!selector) return;

    // Daftarkan gerbong playlist ke engine jika engine masih baru kosong
    if (core.tracksData.length === 0) {
      core.tracksData = Array.from(selector.options).map((opt: any) => ({
        id: extractYouTubeId(opt.getAttribute('data-url')),
        title: opt.getAttribute('data-title'),
        artist: opt.getAttribute('data-artist')
      })).filter(t => t.id !== null);
      
      core.init(); // Nyalakan mesin utama YouTube
    }

    // Fungsi menggambar ulang UI berdasarkan kondisi terkini Core Engine
    function renderVisualState() {
      const activeTrack = core.tracksData[core.currentTrackIndex];
      if (!activeTrack) return;

      if (titleEl && titleEl.innerText !== activeTrack.title) {
        const textElements = [titleEl, artistEl];
        gsap.to(textElements, {
          opacity: 0, y: -5, duration: 0.15,
          onComplete: () => {
            if (titleEl) titleEl.innerText = activeTrack.title;
            if (artistEl) artistEl.innerText = activeTrack.artist;
            selector.value = core.currentTrackIndex.toString();
            gsap.fromTo(textElements, { opacity: 0, y: 5 }, { opacity: 1, y: 0, duration: 0.15 });
          }
        });
      } else {
        selector.value = core.currentTrackIndex.toString();
      }

      if (core.isPlaying) {
        playIcon?.classList.add('hidden'); pauseIcon?.classList.remove('hidden');
        waveContainer?.classList.add('animate-wave-bar');
        gsap.to(waveContainer, { opacity: 1, duration: 0.3 });
      } else {
        playIcon?.classList.remove('hidden'); pauseIcon?.classList.add('hidden');
        waveContainer?.classList.remove('animate-wave-bar');
        gsap.to(waveContainer, { opacity: 0.4, duration: 0.3 });
      }
    }

    // Sambungkan sinyal siaran broadcast dari Core ke Visual UI halaman saat ini
    window.removeEventListener('cyber-audio-sync-signal', renderVisualState);
    window.addEventListener('cyber-audio-sync-signal', renderVisualState);

    // Ikat kontrol tombol fisik halaman aktif ke mesin Core
    selector.onchange = (e: any) => core.switchTrack(parseInt(e.target.value));
    
    if (playBtn) playBtn.onclick = (e) => { e.stopPropagation(); if (core.isPlaying) core.pause(); else core.play(); };
    if (prevBtn) prevBtn.onclick = (e) => { e.stopPropagation(); let pIdx = core.currentTrackIndex - 1; if (pIdx < 0) pIdx = core.tracksData.length - 1; core.switchTrack(pIdx); };
    if (nextBtn) nextBtn.onclick = (e) => { e.stopPropagation(); let nIdx = core.currentTrackIndex + 1; if (nIdx >= core.tracksData.length) nIdx = 0; core.switchTrack(nIdx); };

    // GSAP Hover Magnetic & Entry Animation
    const controls = [prevBtn, playBtn, nextBtn];
    controls.forEach(btn => {
      if (!btn) return;
      btn.onmousemove = (e: MouseEvent) => { const r = btn.getBoundingClientRect(); gsap.to(btn, { x: (e.clientX - r.left - r.width/2) * 0.35, y: (e.clientY - r.top - r.height/2) * 0.35, scale: 1.05, duration: 0.2 }); };
      btn.onmouseleave = () => { gsap.to(btn, { x: 0, y: 0, scale: 1, duration: 0.6, ease: "elastic.out(1, 0.35)" }); };
    });

    if (widget) {
      gsap.killTweensOf(widget);
      gsap.fromTo(widget, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.1 });
    }

    renderVisualState(); // Render keadaan visual saat kartu pertama kali dimuat di halaman baru
  }

  declare global { interface Window { YT: any; CyberAudioCore: any; onYouTubeIframeAPIReady: (() => void) | undefined; } }
  document.addEventListener('astro:page-load', syncUIWithCoreEngine);
</script>
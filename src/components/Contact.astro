---
// src/components/Contact.astro
const { contactHeading, contactDescription, contactEmail } = Astro.props;
---
<section id="kontak" class="bg-white/10 dark:bg-zinc-900/15 border border-zinc-200/60 dark:border-zinc-900 rounded-3xl p-8 sm:p-10 grid grid-cols-1 md:grid-cols-5 gap-8 items-start shadow-sm font-sans relative overflow-hidden">
  
  <div class="md:col-span-2 space-y-4">
    <div class="space-y-2">
      <span class="text-[10px] font-mono font-bold uppercase tracking-widest text-emerald-500" data-translate>// Secure Communication Uplink</span>
      <h2 data-translate class="text-2xl font-black text-zinc-900 dark:text-zinc-50 tracking-tight">
        {contactHeading || "Mari Berkolaborasi!"}
      </h2>
      <p data-translate class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
        {contactDescription || "Pintu komunikasi saya selalu terbuka untuk mendiskusikan rekayasa perangkat lunak harian."}
      </p>
    </div>

    <div class="pt-2 font-mono text-[11px] text-zinc-400 dark:text-zinc-500 select-all">
      <span class="font-bold">// DIRECT_NODE:</span> <span class="notranslate text-zinc-700 dark:text-zinc-300 hover:text-emerald-500 transition-colors">{contactEmail || 'contact@ryzalfadhillah.com'}</span>
    </div>
  </div>

  <div class="md:col-span-3 w-full font-mono">
    <form id="cyber-contact-form" class="space-y-4 text-xs">
      
      <div class="space-y-1.5">
        <label for="contact-name" class="text-zinc-400 dark:text-zinc-500 font-bold block tracking-wide">// SENDER_NAME</label>
        <input 
          type="text" 
          id="contact-name" 
          name="name" 
          required
          placeholder="Masukkan nama lengkap Anda..."
          class="w-full px-3 py-2.5 rounded-xl bg-white dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 border border-zinc-200 dark:border-zinc-800 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 placeholder-zinc-400 transition-all font-sans text-xs"
        />
      </div>

      <div class="space-y-1.5">
        <label for="contact-email" class="text-zinc-400 dark:text-zinc-500 font-bold block tracking-wide">// SENDER_EMAIL</label>
        <input 
          type="email" 
          id="contact-email" 
          name="email" 
          required
          placeholder="name@email.com"
          class="w-full px-3 py-2.5 rounded-xl bg-white dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 border border-zinc-200 dark:border-zinc-800 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 placeholder-zinc-400 transition-all font-sans text-xs"
        />
      </div>

      <div class="space-y-1.5">
        <label for="contact-message" class="text-zinc-400 dark:text-zinc-500 font-bold block tracking-wide">// MESSAGE</label>
        <textarea 
          id="contact-message" 
          name="message" 
          rows="4"
          required
          placeholder="Tulis pesan penawaran atau kerja sama di sini..."
          class="w-full px-3 py-2.5 rounded-xl bg-white dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 border border-zinc-200 dark:border-zinc-800 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 placeholder-zinc-400 transition-all font-sans text-xs resize-none"
        ></textarea>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-2">
        <div id="form-status-indicator" class="text-[10px] text-zinc-400 dark:text-zinc-500 font-bold flex items-center gap-1.5 bg-zinc-500/5 px-3 py-2 rounded-xl border border-zinc-200/20 shrink-0 select-none">
          <span id="status-dot" class="w-1.5 h-1.5 rounded-full bg-zinc-400 animate-pulse"></span>
          <span id="status-text">[STATUS] READY_FOR_UPLINK</span>
        </div>

        <button 
          type="submit" 
          id="email-magnetic-btn"
          class="inline-block px-6 py-3 bg-transparent border border-emerald-500 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-500 hover:text-zinc-950 dark:hover:text-zinc-950 font-extrabold text-xs font-mono rounded-xl shadow-md transition-colors duration-300 will-change-transform cursor-pointer select-none text-center"
        >
          TRANSMIT_MESSAGE ↗
        </button>
      </div>
    </form>
  </div>
</section>

<div 
  id="cyber-toast-notification" 
  class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] w-[92%] max-w-sm pointer-events-none opacity-0 invisible transform -translate-y-6 select-none font-mono text-xs"
>
  <div class="p-4 rounded-2xl border border-zinc-200/60 dark:border-zinc-800/50 bg-white/95 dark:bg-zinc-950/95 shadow-2xl flex gap-3.5 items-start backdrop-blur-md">
    <div id="toast-icon-wrapper" class="w-6 h-6 rounded-lg flex items-center justify-center text-[10px] font-black shrink-0"></div>
    <div class="flex-1 space-y-0.5 overflow-hidden">
      <div id="toast-status-header" class="font-black tracking-wider text-[11px]"></div>
      <p id="toast-message-body" class="text-zinc-500 dark:text-zinc-400 font-sans leading-snug text-[11px]"></p>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { runDynamicTranslationEngine } from '../utils/translator';

  function initSmartContactModule() {
    const btn = document.getElementById('email-magnetic-btn') as HTMLButtonElement;
    const form = document.getElementById('cyber-contact-form') as HTMLFormElement;
    const statusText = document.getElementById('status-text');
    const statusDot = document.getElementById('status-dot');

    const nameInput = document.getElementById('contact-name') as HTMLInputElement;
    const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;

    // Elemen Toast Dom
    const toastBox = document.getElementById('cyber-toast-notification');
    const toastIcon = document.getElementById('toast-icon-wrapper');
    const toastHeader = document.getElementById('toast-status-header');
    const toastBody = document.getElementById('toast-message-body');

    // 🌟 FIX UTAMA: Fungsi khusus untuk mentranslasikan placeholder input secara dinamis
    function translatePlaceholders() {
      if (!nameInput || !messageInput) return;
      const lang = localStorage.getItem('site-lang') || 'id';

      if (lang === 'id') {
        nameInput.placeholder = "Masukkan nama lengkap Anda...";
        messageInput.placeholder = "Tulis pesan penawaran atau kerja sama di sini...";
      } else {
        nameInput.placeholder = "Enter your full name...";
        messageInput.placeholder = "Write your proposal or cooperation message here...";
      }
    }

    // Jalankan sekali saat halaman dimuat & dengerin sinyal klik ganti bahasa dari Header
    translatePlaceholders();
    window.addEventListener('lang-changed-signal', translatePlaceholders);

    // FUNCTION TOAST BANNER GSAP
    function triggerCyberToast(type: 'success' | 'error', message: string) {
      if (!toastBox || !toastIcon || !toastHeader || !toastBody) return;
      const lang = localStorage.getItem('site-lang') || 'id';

      if (type === 'success') {
        toastIcon.className = "w-6 h-6 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-500 shrink-0 font-bold";
        toastIcon.innerText = "✓";
        toastHeader.className = "font-black tracking-wider text-[11px] text-emerald-600 dark:text-emerald-400";
        toastHeader.innerText = lang === 'id' ? "[UPLINK_SUCCESS]" : "[TRANSMISSION_SUCCESS]";
      } else {
        toastIcon.className = "w-6 h-6 rounded-lg bg-red-500/10 border border-red-500/30 flex items-center justify-center text-red-500 shrink-0 font-bold";
        toastIcon.innerText = "✕";
        toastHeader.className = "font-black tracking-wider text-[11px] text-red-600 dark:text-red-400";
        toastHeader.innerText = "[TRANSMISSION_ERROR]";
      }

      toastBody.innerText = message;

      gsap.killTweensOf(toastBox);
      const tl = gsap.timeline();
      toastBox.classList.remove('invisible');
      
      tl.to(toastBox, {
        opacity: 1,
        y: 20,
        duration: 0.4,
        ease: "power3.out"
      });

      tl.to(toastBox, {
        opacity: 0,
        y: -24,
        duration: 0.4,
        delay: 3.5,
        ease: "power2.in",
        onComplete: () => {
          toastBox.classList.add('invisible');
        }
      });
    }

    // MAGNETIK BTN GSAP
    if (btn) {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(btn, {
          x: x * 0.35,
          y: y * 0.35,
          scale: 1.02,
          duration: 0.2,
          ease: "power2.out"
        });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          scale: 1,
          duration: 0.6,
          ease: "elastic.out(1, 0.35)"
        });
      });
    }

    // ONSUBMIT INTEGRATION
    if (form && statusText && statusDot && btn) {
      form.onsubmit = async (e) => {
        e.preventDefault();

        statusText.innerText = "[PROCESS] ENCRYPTING_PAYLOAD...";
        statusDot.className = "w-1.5 h-1.5 rounded-full bg-amber-500 animate-ping";
        btn.disabled = true;
        btn.classList.add('opacity-40', 'cursor-not-allowed');

        const formData = new FormData(form);
        const lang = localStorage.getItem('site-lang') || 'id';

        const formId = import.meta.env.PUBLIC_FORMSPREE_ID;

        try {
          const response = await fetch(`https://formspree.io/f/${formId}`, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });

          if (response.ok) {
            statusText.innerText = "[SUCCESS] PAYLOAD_TRANSMITTED_OK";
            statusDot.className = "w-1.5 h-1.5 rounded-full bg-emerald-500 animate-none";
            
            const msgSuccess = lang === 'id' 
              ? "Pesan Anda berhasil dienkripsi dan dikirim langsung ke email Ryzal!" 
              : "Your connection payload was encrypted and dispatched directly to Ryzal's core email inbox!";
            triggerCyberToast('success', msgSuccess);
            
            form.reset();
          } else {
            throw new Error('Bad request');
          }
        } catch (error) {
          statusText.innerText = "[ERROR] TRANSMISSION_FAILED_400";
          statusDot.className = "w-1.5 h-1.5 rounded-full bg-red-500 animate-none";
          
          const msgError = lang === 'id'
            ? "Gagal mengirim! Periksa koneksi internet Anda atau pastikan endpoint URL valid."
            : "Transmission node failed! Verify your network links or core endpoint registry.";
          triggerCyberToast('error', msgError);
        } finally {
          setTimeout(() => {
            btn.disabled = false;
            btn.classList.remove('opacity-40', 'cursor-not-allowed');
            statusText.innerText = "[STATUS] READY_FOR_UPLINK";
            statusDot.className = "w-1.5 h-1.5 rounded-full bg-zinc-400 animate-pulse";
          }, 4000);
        }
      };
    }
  }

  document.addEventListener('astro:page-load', initSmartContactModule);
</script>
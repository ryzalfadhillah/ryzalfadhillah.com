---
// src/components/Contact.astro
const { contactHeading, contactDescription, contactEmail } = Astro.props;
---
<section id="kontak" class="bg-zinc-100 dark:bg-zinc-900/50 border border-zinc-200/60 dark:border-zinc-900 rounded-3xl p-8 sm:p-10 grid grid-cols-1 md:grid-cols-3 gap-6 items-center shadow-sm">
  <div class="md:col-span-2 space-y-2">
    <h2 class="text-2xl font-black text-zinc-900 dark:text-zinc-50 tracking-tight">
      {contactHeading || "Mari Berkolaborasi!"}
    </h2>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-md">
      {contactDescription || "Pintu komunikasi saya selalu terbuka untuk mendiskusikan rekayasa perangkat lunak harian."}
    </p>
  </div>
  <div class="md:text-right">
    <a 
      id="email-magnetic-btn"
      href={`mailto:${contactEmail || 'contact@ryzalfadhillah.com'}`} 
      class="inline-block px-6 py-3 bg-transparent border border-emerald-500 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-500 hover:text-zinc-950 dark:hover:text-zinc-950 font-extrabold text-xs font-mono rounded-xl shadow-md transition-colors duration-300 will-change-transform cursor-pointer select-none"
    >
      Kirim Email Kerja
    </a>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  function initMagneticContact() {
    const btn = document.getElementById('email-magnetic-btn');
    
    if (btn) {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        // Efek hisapan magnetik spasial halus 35%
        gsap.to(btn, {
          x: x * 0.35,
          y: y * 0.35,
          scale: 1.02,
          duration: 0.2,
          ease: "power2.out"
        });
      });

      btn.addEventListener('mouseleave', () => {
        // Efek membal elastis pegas karet kembali ke koordinat awal
        gsap.to(btn, {
          x: 0,
          y: 0,
          scale: 1,
          duration: 0.6,
          ease: "elastic.out(1, 0.35)"
        });
      });
    }
  }

  // Pastikan logika diikat erat pada setiap muatan halaman router
  document.addEventListener('astro:page-load', initMagneticContact);
</script>
---
// src/components/Header.astro
const { githubUsername } = Astro.props;

const currentPath = Astro.url.pathname;

const getNavLinkClass = (targetPath: string, exact = false) => {
  const isActive = exact ? currentPath === targetPath : currentPath.startsWith(targetPath);
  return isActive 
    ? "text-emerald-500 font-bold transition-colors cursor-default" 
    : "text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-200 transition-colors";
};
---
<header class="flex justify-between items-center py-4 border-b border-zinc-200 dark:border-zinc-900">
  <span class="text-lg font-black tracking-tight bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent select-none">
    {githubUsername ? `${githubUsername}.com` : 'ryzalfadhillah.com'}
  </span>
  <nav class="flex items-center gap-6 text-sm font-medium">
    <a href="/" class={getNavLinkClass("/", true)}>Beranda</a>
    <a href="/proyek" class={getNavLinkClass("/proyek", false)}>Proyek</a>
    <a href="/artikel" class={getNavLinkClass("/artikel", false)}>Artikel</a>
    
    <button id="theme-toggle" class="p-2 rounded-xl bg-zinc-200/60 dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 hover:text-emerald-500 cursor-pointer transition-colors" aria-label="Toggle Theme">
      <svg id="theme-icon-sun" class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"/></svg>
      <svg id="theme-icon-moon" class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
    </button>
  </nav>
</header>

<script>
  function attachThemeEngine() {
    const toggle = document.getElementById('theme-toggle');
    toggle?.addEventListener('click', () => {
      const documentElement = document.documentElement;
      documentElement.classList.toggle('dark');
      const isDark = documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      window.dispatchEvent(new Event('theme-changed'));
    });
  }
  document.addEventListener('astro:page-load', attachThemeEngine);
</script>
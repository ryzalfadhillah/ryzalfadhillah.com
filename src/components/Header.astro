---
// src/components/Header.astro
const { githubUsername } = Astro.props;
const currentPath = Astro.url.pathname;

const getNavLinkClass = (targetPath: string, exact = false) => {
  const isActive = exact ? currentPath === targetPath : currentPath.startsWith(targetPath);
  return isActive 
    ? "text-emerald-500 font-bold transition-colors cursor-default" 
    : "text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-200 transition-colors";
};
---
<header 
  id="main-cyber-header" 
  class="sticky top-4 z-50 rounded-2xl border border-white/20 dark:border-zinc-800/40 bg-white/10 dark:bg-zinc-900/15 backdrop-blur-2xl shadow-lg transition-all duration-300 px-4 sm:px-6 py-3.5 select-none"
>
  <div class="flex justify-between items-center w-full gap-4">
    
    <span class="text-sm sm:text-base font-black tracking-tight bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent truncate max-w-[140px] xs:max-w-[180px] sm:max-w-none">
      {githubUsername ? `${githubUsername}.com` : 'ryzalfadhillah.com'}
    </span>

    <div class="flex items-center gap-3 sm:gap-4 shrink-0">
      
      <nav class="hidden md:flex items-center gap-5 text-xs sm:text-sm font-semibold">
        <a href="/" class={getNavLinkClass("/", true)} data-translate>Beranda</a>
        <a href="/proyek" class={getNavLinkClass("/proyek", false)} data-translate>Proyek</a>
        <a href="/artikel" class={getNavLinkClass("/artikel", false)} data-translate>Artikel</a>
      </nav>
      
      <div class="flex items-center gap-2 border-l border-zinc-200/40 dark:border-zinc-800/40 pl-3 sm:pl-4">
        
        <button id="site-language-switcher" class="px-2 py-0.5 rounded-md bg-white/20 dark:bg-zinc-900/40 border border-white/20 dark:border-zinc-800/40 text-[9px] font-mono font-bold text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 cursor-pointer transition-colors">ID</button>
        
        <button id="theme-toggle" class="p-1.5 rounded-lg bg-white/20 dark:bg-zinc-900/40 border border-white/20 dark:border-zinc-800/40 text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 cursor-pointer transition-colors flex items-center justify-center" aria-label="Ubah Tema">
          <svg id="theme-icon-sun" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"/></svg>
          <svg id="theme-icon-moon" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>

        <button 
          id="mobile-menu-toggle" 
          class="md:hidden p-1.5 rounded-lg bg-white/20 dark:bg-zinc-900/40 border border-white/20 dark:border-zinc-800/40 text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 cursor-pointer transition-colors flex items-center justify-center" 
          aria-label="Buka Menu Navigasi"
        >
          <svg id="menu-icon-hamburger" class="w-3.5 h-3.5 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="menu-icon-close" class="w-3.5 h-3.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

      </div>
    </div>
  </div>

  <nav 
    id="mobile-nav-links" 
    class="hidden flex-col gap-2.5 pt-3.5 pb-1 border-t border-zinc-200/20 dark:border-zinc-800/20 mt-3 text-xs font-bold tracking-wide transition-all duration-300"
  >
    <a href="/" class={`${getNavLinkClass("/", true)} py-2 px-3 rounded-xl hover:bg-zinc-500/10 block`} data-translate>Beranda</a>
    <a href="/proyek" class={`${getNavLinkClass("/proyek", false)} py-2 px-3 rounded-xl hover:bg-zinc-500/10 block`} data-translate>Proyek</a>
    <a href="/artikel" class={`${getNavLinkClass("/artikel", false)} py-2 px-3 rounded-xl hover:bg-zinc-500/10 block`} data-translate>Artikel</a>
  </nav>

</header>

<script>
  import { runDynamicTranslationEngine } from '../utils/translator';
  
  function initHeaderSystem() {
    // 1. KENDALI LOGIKA MODE GELAP & TERANG
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('theme-icon-sun');
    const moonIcon = document.getElementById('theme-icon-moon');
    const updateIcons = () => {
      if (document.documentElement.classList.contains('dark')) { sunIcon?.classList.remove('hidden'); moonIcon?.classList.add('hidden'); }
      else { sunIcon?.classList.add('hidden'); moonIcon?.classList.remove('hidden'); }
    };
    updateIcons();
    if (toggle) toggle.onclick = () => { document.documentElement.classList.toggle('dark'); localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light'); updateIcons(); };

    // 2. KENDALI LOGIKA SWITCHER BAHASA
    const langBtn = document.getElementById('site-language-switcher');
    let currentLang = localStorage.getItem('site-lang') || 'id';
    if (langBtn) langBtn.innerText = currentLang.toUpperCase();
    runDynamicTranslationEngine();
    if (langBtn) {
      langBtn.onclick = async () => {
        const nextLang = currentLang === 'id' ? 'en' : 'id';
        localStorage.setItem('site-lang', nextLang);
        langBtn.innerText = nextLang.toUpperCase();
        currentLang = nextLang;
        await runDynamicTranslationEngine();
        window.dispatchEvent(new CustomEvent('lang-changed-signal'));
      };
    }

    // 🌟 3. LOGIKA INDEPENDEN EXPANDING MOBILE HAMBURGER MENU
    const menuToggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileNavLinks = document.getElementById('mobile-nav-links');
    const hamburgerIcon = document.getElementById('menu-icon-hamburger');
    const closeIcon = document.getElementById('menu-icon-close');

    if (menuToggleBtn && mobileNavLinks) {
      menuToggleBtn.onclick = (e) => {
        e.stopPropagation();
        const isOpen = !mobileNavLinks.classList.contains('hidden');
        
        if (isOpen) {
          // Tutup Menu Drawer
          mobileNavLinks.classList.add('hidden');
          hamburgerIcon?.classList.remove('hidden');
          hamburgerIcon?.classList.add('block');
          closeIcon?.classList.remove('block');
          closeIcon?.classList.add('hidden');
        } else {
          // Buka & Lebarkan Kapsul Menu
          mobileNavLinks.classList.remove('hidden');
          mobileNavLinks.classList.add('flex');
          hamburgerIcon?.classList.remove('block');
          hamburgerIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
          closeIcon?.classList.add('block');
        }
      };

      // Otomatis tutup drawer menu jika user mengklik halaman luar saat menu terbuka
      document.addEventListener('click', () => {
        if (!mobileNavLinks.classList.contains('hidden')) {
          mobileNavLinks.classList.add('hidden');
          hamburgerIcon?.classList.remove('hidden');
          hamburgerIcon?.classList.add('block');
          closeIcon?.classList.remove('block');
          closeIcon?.classList.add('hidden');
        }
      });
    }
  }

  // Ikat logika agar awet melintasi Astro View Transitions (ClientRouter)
  document.addEventListener('astro:page-load', initHeaderSystem);
</script>
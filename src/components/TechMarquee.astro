---
// src/components/TechMarquee.astro
const { skills } = Astro.props;
const techStack = skills && skills.length > 0 
  ? skills 
  : ['Astro Framework', 'React 19', 'Tailwind CSS v4', 'TypeScript', 'Node.js', 'GSAP Animation', 'Sanity CMS'];
const doubleTechStack = [...techStack, ...techStack];
---
<div class="space-y-3">
  <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 px-1 flex items-center gap-2">
    <span class="w-1 h-1 rounded-full bg-emerald-400 animate-ping"></span> Core Tech Weaponry
  </h2>
  <div class="w-full relative overflow-hidden py-4 bg-zinc-100/50 dark:bg-zinc-900/30 border-y border-zinc-200/80 dark:border-zinc-900/60 mask-gradient">
    <div class="absolute left-0 top-0 h-full w-16 bg-gradient-to-r from-zinc-50 dark:from-zinc-950 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 h-full w-16 bg-gradient-to-l from-zinc-50 dark:from-zinc-950 to-transparent z-10 pointer-events-none"></div>
    
    <div id="tech-marquee-track" class="flex gap-8 items-center whitespace-nowrap will-change-transform">
      {doubleTechStack.map((tech) => (
        <div class="flex items-center gap-3 text-sm md:text-base font-bold tracking-tight text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors cursor-default select-none">
          <span>{tech}</span>
          <span class="text-zinc-300 dark:text-zinc-800 font-normal">•</span>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function initTechMarquee() {
    const track = document.getElementById('tech-marquee-track');
    if (track) {
      // Hitung setengah lebar total lintasan untuk titik balik loop murni
      const trackWidth = track.scrollWidth / 2;
      
      // Amankan agar tidak terjadi duplikasi tween saat transisi halaman
      gsap.killTweensOf(track);
      gsap.set(track, { x: 0 });

      const marqueeTween = gsap.to(track, {
        x: -trackWidth,
        ease: "none",
        duration: 20,
        repeat: -1,
        runBackwards: false
      });

      track.addEventListener('mouseenter', () => marqueeTween.pause());
      track.addEventListener('mouseleave', () => marqueeTween.play());
    }
  }

  // Kunci utama penyelemat siklus navigasi Astro v7
  document.addEventListener('astro:page-load', initTechMarquee);
</script>
---
// src/components/TerminalLogs.astro
// Tangkap data dinamis dari Sanity CMS melalui halaman utama
const { skills, focusCompetency, projects } = Astro.props;

const projectTitles = projects?.map((p: any) => p.title) || [];
---

<div 
  id="cyber-terminal-card" 
  data-sanity-skills={JSON.stringify(skills || [])}
  data-sanity-about={focusCompetency || "Software Engineer Portfolio Matrix."}
  data-sanity-projects={JSON.stringify(projectTitles)}
  class="w-full rounded-2xl bg-zinc-100/70 border border-zinc-200/80 dark:bg-zinc-950 dark:border-zinc-900 overflow-hidden flex flex-col shadow-sm dark:shadow-xl font-mono text-xs text-zinc-800 dark:text-zinc-300 h-full min-h-[340px] transition-all duration-300"
>
  
  <div class="flex items-center justify-between px-4 py-2.5 bg-zinc-200/50 border-b border-zinc-200 dark:bg-zinc-900 dark:border-zinc-900 select-none shrink-0">
    <div class="flex items-center gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full bg-zinc-300 dark:bg-zinc-800"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-zinc-300 dark:bg-zinc-800"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-zinc-300 dark:bg-zinc-800"></div>
    </div>
    <span class="text-[10px] text-zinc-400 dark:text-zinc-500 font-bold tracking-wider uppercase">core_kernel_v2.6.sh</span>
    <span class="w-4"></span>
  </div>

  <div id="terminal-screen-scroll" class="p-4 flex-1 overflow-y-auto space-y-2 scrollbar-thin scrollbar-thumb-zinc-300 dark:scrollbar-thumb-zinc-800 text-[11px] leading-relaxed">
    <div id="terminal-logs-history" class="space-y-2">
      <p class="text-zinc-400 dark:text-zinc-600 font-bold">// Cybernetic Terminal Connection Stabilized.</p>
      <p class="text-zinc-600 dark:text-zinc-400">Selamat datang di sistem repositori lokal saya. Ketik <span class="text-emerald-600 dark:text-emerald-400 font-bold font-mono">help</span> untuk melihat daftar komando harian yang tersedia.</p>
    </div>

    <div class="flex items-center gap-1.5 pt-1 text-zinc-700 dark:text-zinc-300">
      <span class="text-emerald-600 dark:text-emerald-500 font-bold shrink-0">guest@ryzalfadhillah:~$</span>
      <input 
        type="text" 
        id="live-terminal-input" 
        class="bg-transparent border-none outline-none flex-1 text-emerald-600 dark:text-emerald-400 font-bold p-0 m-0 caret-emerald-600 dark:caret-emerald-400 focus:ring-0 focus:border-none" 
        autocomplete="off"
        spellcheck="false"
        aria-label="Terminal Command Input"
      />
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function initInteractiveTerminal() {
    const card = document.getElementById('cyber-terminal-card');
    const screenScroll = document.getElementById('terminal-screen-scroll');
    const historyBox = document.getElementById('terminal-logs-history');
    const input = document.getElementById('live-terminal-input') as HTMLInputElement;

    if (!input || !historyBox || !screenScroll || !card) return;

    card.addEventListener('click', () => input.focus());

    const rawSkills = card.getAttribute('data-sanity-skills');
    const sanityAbout = card.getAttribute('data-sanity-about');
    const rawProjects = card.getAttribute('data-sanity-projects');
    
    const skillsList = rawSkills ? JSON.parse(rawSkills) : [];
    const projectsList = rawProjects ? JSON.parse(rawProjects) : [];

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const fullRawCommand = input.value;
        const cleanedCommand = fullRawCommand.trim().toLowerCase();
        const args = cleanedCommand.split(' ');
        const primaryCmd = args[0];

        if (cleanedCommand === '') return;

        // Echo command user (responsif dual-theme)
        const echoLine = document.createElement('div');
        echoLine.className = 'flex items-center gap-1.5 pt-1';
        echoLine.innerHTML = `<span class="text-zinc-400 dark:text-zinc-600 font-bold">guest@ryzalfadhillah:~$</span> <span class="text-zinc-900 dark:text-zinc-100 font-medium">${fullRawCommand}</span>`;
        historyBox.appendChild(echoLine);

        // Kontainer jawaban responsif terhadap light & dark mode
        const responseBlock = document.createElement('div');
        responseBlock.className = 'space-y-1 pl-2 border-l border-zinc-300 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400';

        switch (primaryCmd) {
          case 'help':
            responseBlock.innerHTML = `
              <p class="text-zinc-400 dark:text-zinc-500 font-bold">// Daftar Komando Inti Kernel System:</p>
              <p><span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 inline-block">about</span> - Menampilkan ringkasan biodata biografi harian.</p>
              <p><span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 inline-block">skills</span> - Membongkar persenjataan core teknologi stack harian.</p>
              <p><span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 inline-block">projects</span> - Mencetak daftar proyek asli database Sanity.</p>
              <p><span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 inline-block">music</span> - Kontrol playlist [music play / music pause / music next].</p>
              <p><span class="text-emerald-600 dark:text-emerald-400 font-bold w-20 inline-block">clear</span> - Membersihkan seluruh riwayat tumpukan logs.</p>
            `;
            break;

          case 'about':
            responseBlock.innerHTML = `
              <p class="text-zinc-800 dark:text-zinc-200 font-bold">Ryzal Fadhillah — Software Engineer</p>
              <p class="leading-relaxed">${sanityAbout}</p>
            `;
            break;

          case 'skills':
            let skillsHtml = `<p class="text-zinc-400 dark:text-zinc-500 font-bold">// Core Tech Weaponry Arsenal (Live Sanity CMS):</p>`;
            if (skillsList.length > 0) {
              skillsList.forEach((s: string) => {
                skillsHtml += `<p class="text-zinc-700 dark:text-zinc-300 flex items-center gap-1.5"><span class="text-emerald-600 dark:text-emerald-500">•</span> ${s}</p>`;
              });
            } else {
              skillsHtml += `<p class="italic text-zinc-400">Belum ada skill terdaftar.</p>`;
            }
            responseBlock.innerHTML = skillsHtml;
            break;

          case 'projects':
            let projectsHtml = `<p class="text-zinc-400 dark:text-zinc-500 font-bold">// Fetching Blueprint Database (Live Sanity CMS)...</p>`;
            if (projectsList.length > 0) {
              projectsList.forEach((title: string, index: number) => {
                projectsHtml += `<p class="text-zinc-800 dark:text-zinc-200">${index + 1}. ${title}</p>`;
              });
            } else {
              projectsHtml += `<p class="italic text-zinc-400">Belum ada proyek yang diterbitkan.</p>`;
            }
            projectsHtml += `<p class="text-zinc-500 dark:text-zinc-400 pt-1 font-semibold text-emerald-600 dark:text-emerald-400/80">Ketik "go projects" untuk membuka galeri filter visual penuh.</p>`;
            responseBlock.innerHTML = projectsHtml;
            break;

          case 'go':
            if (args[1] === 'projects') {
              responseBlock.innerHTML = `<p class="text-emerald-600 dark:text-emerald-400 font-bold">// Redirecting Hyperlink Spatial Loop...</p>`;
              setTimeout(() => { window.location.href = '/proyek'; }, 600);
            } else if (args[1] === 'artikel' || args[1] === 'blog') {
              responseBlock.innerHTML = `<p class="text-emerald-600 dark:text-emerald-400 font-bold">// Redirecting Hyperlink Archive...</p>`;
              setTimeout(() => { window.location.href = '/artikel'; }, 600);
            } else {
              responseBlock.innerHTML = `<p class="text-red-500 dark:text-red-400 font-bold">// Target navigasi "${args[1] || ''}" tidak valid.</p>`;
            }
            break;

          case 'music':
            const coreAudio = (window as any).CyberAudioCore;
            if (!coreAudio) {
              responseBlock.innerHTML = `<p class="text-amber-600 dark:text-yellow-500 font-bold">// Audio core stream node belum terinisialisasi.</p>`;
            } else {
              const subAction = args[1];
              if (subAction === 'play') { coreAudio.play(); responseBlock.innerHTML = `<p class="text-emerald-600 dark:text-emerald-400 font-bold">▶ Music Node Stream: PLAYED</p>`; }
              else if (subAction === 'pause') { coreAudio.pause(); responseBlock.innerHTML = `<p class="text-amber-600 dark:text-yellow-400 font-bold">⏸ Music Node Stream: PAUSED</p>`; }
              else if (subAction === 'next') {
                let nIdx = coreAudio.currentTrackIndex + 1;
                if (nIdx >= coreAudio.tracksData.length) nIdx = 0;
                coreAudio.switchTrack(nIdx);
                const trackName = coreAudio.tracksData[nIdx]?.title || "Next Track";
                responseBlock.innerHTML = `<p class="text-emerald-600 dark:text-emerald-400 font-bold">⏭ Skip Node Track: Loading "${trackName}"</p>`;
              } else {
                responseBlock.innerHTML = `<p class="text-zinc-400 dark:text-zinc-500 font-bold">// Gunakan parameter: music play, music pause, atau music next</p>`;
              }
            }
            break;

          case 'clear':
            historyBox.innerHTML = `<p class="text-zinc-400 dark:text-zinc-600 font-bold">// Cybernetic Terminal Cleared. Session Reset.</p>`;
            input.value = '';
            return;

          default:
            responseBlock.innerHTML = `<p class="text-red-500 dark:text-red-400 font-bold">// Command Error: Perintah "${primaryCmd}" tidak dikenali kernel.</p>`;
            break;
        }

        historyBox.appendChild(responseBlock);
        input.value = '';
        setTimeout(() => { screenScroll.scrollTop = screenScroll.scrollHeight; }, 20);
      }
    });
  }

  document.addEventListener('astro:page-load', initInteractiveTerminal);
</script>
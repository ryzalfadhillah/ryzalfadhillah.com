---
// src/pages/artikel/[slug].astro
import { client } from '../../lib/sanity';
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';

import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { PortableText } from 'astro-portabletext'

export async function getStaticPaths() {
  const articles = await client.fetch(`*[_type == "article" && defined(slug.current)]`);
  return articles.map((article: any) => ({ params: { slug: article.slug.current } }));
}

const { slug } = Astro.params;
const article = await client.fetch(`*[_type == "article" && slug.current == $slug][0]{ title, publishDate, content, tags, "imageUrl": mainImage.asset->url }`, { slug });
const profile = await client.fetch(`*[_type == "profile"][0]{ name }`);
const tracks = await client.fetch(`*[_type == "track"]{ trackTitle, artist, youtubeUrl }`);

const renderContent = (contentArray: any) => {
  if (!contentArray || contentArray.length === 0) return '<p class="italic text-zinc-400">Konten tulisan kosong.</p>';
  return contentArray.map((block: any) => {
    if (block._type === 'block') {
      const text = block.children?.map((c: any) => c.text).join('') || '';
      if (block.style === 'h2') return `<h2 class="text-2xl font-bold text-zinc-800 dark:text-zinc-100 mt-10 mb-4 border-b border-zinc-100 dark:border-zinc-900 pb-2" data-translate>${text}</h2>`;
      return `<p class="text-zinc-600 dark:text-zinc-300 leading-relaxed mb-6 text-base sm:text-lg" data-translate>${text}</p>`;
    }
    return '';
  }).join('');
};
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{article?.title}</title>
    <script is:inline>
      const applyThemeEngine = () => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        if (theme === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      };
      applyThemeEngine();
      document.addEventListener('astro:after-swap', applyThemeEngine);
    </script>
    <ClientRouter />
  </head>
  <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 font-sans min-h-screen transition-colors duration-300">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 space-y-10">
      <Header />
      <AudioPlayer tracks={tracks} transition:persist="cyber-audio" />
      
      <div class="pt-2">
        <a href="/artikel" class="inline-flex items-center gap-2 text-xs font-mono font-bold text-zinc-400 hover:text-emerald-500 border border-zinc-200 dark:border-zinc-900 bg-white dark:bg-zinc-950 px-4 py-2 rounded-xl" data-translate>← KEMBALI</a>
      </div>

      <article class="space-y-8 opacity-0 transform translate-y-6" id="main-article-body">
        <header class="space-y-4 border-b border-zinc-200/80 dark:border-zinc-900 pb-6">
          <div class="flex flex-wrap items-center gap-2 text-xs font-mono font-bold text-zinc-400">
            <span class="text-emerald-500" data-translate>// Node Arsip Tulisan</span>
            <span>•</span>
            {article?.tags?.map((tag: string) => <span class="text-emerald-500">#{tag}</span>)}
            <span>•</span>
            <span data-translate>{article?.publishDate ? new Date(article.publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Mode Draf'}</span>
          </div>
          <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-zinc-900 dark:text-zinc-50" data-translate>{article?.title}</h1>
        </header>

        {article?.imageUrl && (
          <div id="article-hero-cover-wrap" class="w-full h-[240px] sm:h-[380px] rounded-3xl overflow-hidden bg-zinc-900 shadow-xl relative">
            <img src={article.imageUrl} alt={article.title} class="w-full h-full object-cover opacity-85" />
          </div>
        )}

        <!-- <div class="prose max-w-none text-zinc-800 dark:text-zinc-200 pt-2" set:html={renderContent(article?.content)}></div> -->
        <div class="konten-artikel">
          <PortableText value={article?.content} />
        </div>
      </article>
      <Footer name={profile?.name} />
    </div>
  </body>
</html>

<script>
  import { gsap } from 'gsap';
  import { runDynamicTranslationEngine } from '../../utils/translator';
  document.addEventListener('astro:page-load', () => {
    runDynamicTranslationEngine();
    const articleContainer = document.getElementById('main-article-body');
    if (articleContainer) gsap.to(articleContainer, { opacity: 1, y: 0, duration: 0.6 });
  });
</script>

<style is:global>
  /* Styling untuk Heading / Judul */
  .konten-artikel h1 { font-size: 2.25rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .konten-artikel h2 { font-size: 1.875rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .konten-artikel h3 { font-size: 1.5rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; }

  /* Styling untuk Bullet List (ul) */
  .konten-artikel ul { list-style-type: disc; padding-left: 1.5rem; margin-top: 0.75rem; margin-bottom: 0.75rem; }

  /* Styling untuk Numbered List (ol) */
  .konten-artikel ol { list-style-type: decimal; padding-left: 1.5rem; margin-top: 0.75rem; margin-bottom: 0.75rem; }

  /* Styling untuk List Item (li) */
  .konten-artikel li { margin-top: 0.25rem; margin-bottom: 0.25rem; }

  /* Spasi antar paragraf biasa biar ga terlalu rapat */
  .konten-artikel p { margin-bottom: 1rem; line-height: 1.75; }
</style>
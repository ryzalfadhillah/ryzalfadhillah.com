---
// src/pages/artikel/index.astro
import { client } from '../../lib/sanity';
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';

import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';

const articles = await client.fetch(`*[_type == "article" && defined(slug.current)] | order(publishDate desc){ title, slug, publishDate, content, tags, "imageUrl": mainImage.asset->url }`);
const profile = await client.fetch(`*[_type == "profile"][0]{ name }`);
const tracks = await client.fetch(`*[_type == "track"]{ trackTitle, artist, youtubeUrl }`);

const getSnippet = (contentArray: any) => {
  if (!contentArray || contentArray.length === 0) return "Klik untuk membaca pembahasan lengkap.";
  const firstTextBlock = contentArray.find((block: any) => block._type === 'block' && block.style === 'normal');
  if (!firstTextBlock) return "Klik untuk membaca pembahasan lengkap.";
  const text = firstTextBlock.children?.map((c: any) => c.text).join('') || '';
  return text.length > 110 ? text.substring(0, 110) + '...' : text;
};
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artikel & Catatan</title>
    <script is:inline>
      const applyThemeEngine = () => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        if (theme === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      };
      applyThemeEngine();
      document.addEventListener('astro:after-swap', applyThemeEngine);
    </script>
    <ClientRouter />
  </head>
  <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 font-sans min-h-screen transition-colors duration-300">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 space-y-12">
      <Header />
      <AudioPlayer tracks={tracks} transition:persist="cyber-audio" />
      
      <section class="space-y-3 pt-4 opacity-0 transform translate-y-6" id="blog-header">
        <span class="text-[10px] font-mono font-bold uppercase tracking-widest text-emerald-500" data-translate>// Arsip Catatan</span>
        <h1 class="text-4xl font-black tracking-tight sm:text-5xl" data-translate>Artikel dan Catatan Harian</h1>
        <p class="text-zinc-500 dark:text-zinc-400 max-w-2xl text-base sm:text-lg" data-translate>Berbagi dokumentasi harian, teknologi, dan hal lainnya yang ada dikepala.</p>
      </section>

      <main class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
        {articles?.map((article: any) => (
          <a href={`/artikel/${article.slug?.current}`} class="article-display-card group rounded-3xl bg-white border border-zinc-200 dark:bg-zinc-900/20 dark:border-zinc-900 overflow-hidden flex flex-col justify-between hover:border-emerald-500/30 shadow-sm hover:shadow-xl transition-all duration-500 opacity-0 transform translate-y-8 min-h-[420px]">
            <div class="w-full h-[48%] overflow-hidden bg-zinc-100 dark:bg-zinc-950 relative">
              {article.imageUrl ? <img src={article.imageUrl} alt={article.title} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-700 opacity-90" loading="lazy" /> : <div class="w-full h-full flex items-center justify-center font-mono text-[10px] text-zinc-400" data-translate>// Gambar Sampul Kosong</div>}
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between space-y-4">
              <div class="space-y-3">
                <div class="flex flex-wrap justify-between items-center gap-2 text-[10px] font-mono uppercase font-bold text-zinc-400">
                  <div class="flex flex-wrap gap-1.5">{article.tags?.map((tag: string) => <span class="px-2 py-0.5 rounded bg-zinc-100 text-emerald-600 dark:bg-zinc-900 dark:text-emerald-400 border border-zinc-200/40">{tag}</span>)}</div>
                  <span data-translate>{article.publishDate ? new Date(article.publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Draf'}</span>
                </div>
                <h2 class="text-xl font-black tracking-tight text-zinc-800 dark:text-zinc-100 group-hover:text-emerald-500 line-clamp-2" data-translate>{article.title}</h2>
                <p class="text-xs sm:text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2 font-medium" data-translate>{getSnippet(article.content)}</p>
              </div>
              <div class="text-xs font-bold text-emerald-600 dark:text-emerald-400 flex items-center gap-1 border-t border-zinc-100 dark:border-zinc-900 pt-3" data-translate>Baca Artikel Selengkapnya <span class="arrow-move">→</span></div>
            </div>
          </a>
        ))}
      </main>
      <Footer name={profile?.name} />
    </div>
  </body>
</html>

<script>
  import { gsap } from 'gsap';
  import { runDynamicTranslationEngine } from '../../utils/translator';
  document.addEventListener('astro:page-load', () => {
    runDynamicTranslationEngine();
    const header = document.getElementById('blog-header');
    const cards = document.querySelectorAll('.article-display-card');
    if (header) gsap.to(header, { opacity: 1, y: 0, duration: 0.6 });
    if (cards.length > 0) gsap.to(cards, { opacity: 1, y: 0, stagger: 0.12, duration: 0.8 });
  });
</script>
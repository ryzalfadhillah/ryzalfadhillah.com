---
// src/pages/index.astro
import { client } from '../lib/sanity';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

import Home from '../components/Home.astro';

const profile = await client.fetch(`
  *[_type == "profile"][0]{
    name, bio, githubUsername, "cvUrl": cvFile.asset->url,
    languages, certifications, experiences, education,
    socialLinks, contactEmail, contactHeading, contactDescription,
    skills, focusCompetency
  }
`);

const projects = await client.fetch(`
  *[_type == "project" && featured == true && !(_id in path('drafts.**'))]{
    title, 
    description, 
    slug, 
    technologies, 
    "imageUrl": thumbnail.asset->url,
    liveLink, 
    gitLink
  }
`);

const latestArticles = await client.fetch(`
  *[_type == "article"] | order(_createdAt desc)[0..1]{
    title, slug, category, _createdAt
  }
`);

const tracks = await client.fetch(`
  *[_type == "track"]{
    trackTitle,
    artist,
    youtubeUrl
  }
`);
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile?.name || "Ryzal Fadhillah"} | Developer Hub</title>
    
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2280%22>⚡</text></svg>" />
    
    <ClientRouter />
    
    <script is:inline>
      const applyThemeEngine = () => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        if (theme === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      };

      applyThemeEngine();
      document.addEventListener('astro:after-swap', applyThemeEngine);
    </script>
  </head>
  
  <body class="bg-zinc-50 text-zinc-900 dark:bg-[#08090a] dark:text-zinc-100 font-sans min-h-screen transition-colors duration-500 relative selection:bg-emerald-500/30">
    
    <div class="relative w-full min-h-screen z-10">
      
      <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden select-none">
        
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(128,128,128,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(128,128,128,0.03)_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
        
        <div class="absolute inset-0 bg-[radial-gradient(rgba(128,128,128,0.04)_1px,transparent_1px)] dark:bg-[radial-gradient(rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:20px_20px]"></div>
        
        <div class="absolute top-[-15%] left-[-10%] w-[600px] h-[600px] bg-gradient-to-tr from-emerald-500/30 to-transparent dark:from-emerald-500/[0.08] rounded-full blur-[110px] animate-[pulse_6s_infinite_alternate]"></div>
        
        <div class="absolute top-[25%] right-[-15%] w-[750px] h-[750px] bg-gradient-to-bl from-cyan-500/30 to-transparent dark:from-cyan-500/[0.07] rounded-full blur-[130px] animate-[pulse_8s_infinite_alternate_2s]"></div>
        
        <div class="absolute bottom-[-5%] left-[5%] w-[550px] h-[550px] bg-gradient-to-br from-purple-500/20 to-transparent dark:from-purple-500/[0.05] rounded-full blur-[120px]"></div>

      </div>

      <div class="relative z-10 w-full h-full">
        <Home profile={profile} projects={projects} latestArticles={latestArticles} tracks={tracks} />
      </div>

    </div>
  </body>
</html>
---
// src/pages/index.astro
import { client } from '../lib/sanity';
import '../styles/global.css';

// 🚀 GROQ PROJECTION: Ambil data profil beserta URL file CV jika ada
const profile = await client.fetch(`
  *[_type == "profile"][0]{
    bio,
    "cvUrl": cvFile.asset->url,
    socialLinks
  }
`);

// 🚀 GROQ PROJECTION: Ambil proyek featured sekaligus langsung tembak URL gambar aslinya
const projects = await client.fetch(`
  *[_type == "project" && featured == true]{
    title,
    description,
    slug,
    tags,
    "imageUrl": thumbnail.asset->url,
    liveLink,
    gitLink
  }
`);
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ryzal Fadhillah | Portofolio</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-sans min-h-screen p-4 md:p-12 selection:bg-emerald-500 selection:text-zinc-950">
    <main class="max-w-6xl mx-auto space-y-8">
      
      <header class="flex justify-between items-center py-4 border-b border-zinc-900">
        <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent">
          ryzalfadhillah.com
        </span>
        <nav class="flex gap-6 text-sm font-medium text-zinc-400">
          <a href="#" class="text-zinc-100 hover:text-emerald-400 transition-colors">Home</a>
          <a href="/artikel" class="hover:text-emerald-400 transition-colors">Artikel</a>
        </nav>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-auto md:auto-rows-[190px]">
        
        <div class="md:col-span-2 md:row-span-2 bg-zinc-900 border border-zinc-800 rounded-3xl p-8 flex flex-col justify-between shadow-xl relative overflow-hidden group">
          <div class="space-y-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 font-bold text-lg">
              R
            </div>
            <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-none text-zinc-50">
              Crafting Digital <br/>Experiences.
            </h1>
            <p class="text-zinc-400 text-base leading-relaxed font-normal pt-2">
              {profile?.bio || "Halo! Saya sedang membangun ruang portofolio interaktif di sini."}
            </p>
          </div>
          
          <div class="flex flex-wrap gap-4 items-center pt-6 relative z-10">
            {profile?.cvUrl && (
              <a href={profile.cvUrl} target="_blank" class="px-5 py-2.5 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold text-sm rounded-xl transition-all shadow-lg shadow-emerald-500/10">
                Unduh CV (PDF)
              </a>
            )}
            <div class="flex gap-3 text-sm text-zinc-400">
              {profile?.socialLinks?.map((link: any) => (
                <a href={link} target="_blank" class="hover:text-emerald-400 transition-colors capitalize font-medium">
                  • {link.includes('github') ? 'GitHub' : link.includes('linkedin') ? 'LinkedIn' : 'Sosmed'}
                </a>
              ))}
            </div>
          </div>
          <div class="absolute -right-12 -bottom-12 w-48 h-48 bg-emerald-500/5 blur-3xl rounded-full group-hover:bg-emerald-500/10 transition-all duration-500"></div>
        </div>

        <div class="md:col-span-2 bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex flex-col justify-between shadow-md">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Persenjataan Utama</h2>
          <div class="flex flex-wrap gap-2 pt-4">
            {['Astro', 'React', 'Tailwind v4', 'TypeScript', 'Node.js', 'GSAP', 'Sanity CMS'].map((tech) => (
              <span class="px-3 py-1.5 bg-zinc-950 border border-zinc-800/80 rounded-xl text-xs font-medium text-zinc-300 shadow-sm">
                {tech}
              </span>
            ))}
          </div>
        </div>

        <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex flex-col justify-between shadow-md hover:border-zinc-700 transition-all">
          <div class="flex justify-between items-start">
            <span class="text-2xl">🎵</span>
            <span class="w-2 h-2 rounded-full bg-zinc-700 animate-pulse"></span>
          </div>
          <div>
            <h3 class="font-bold text-sm text-zinc-300">Widget Musik</h3>
            <p class="text-xs text-zinc-500 mt-1">Akan dihubungkan ke Island Player</p>
          </div>
        </div>

        <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex flex-col justify-between shadow-md">
          <span class="text-3xl font-black text-emerald-400 tracking-tight">2026</span>
          <div>
            <h3 class="font-bold text-sm text-zinc-300">Modern Architecture</h3>
            <p class="text-xs text-zinc-500 mt-1">Headless CMS & Static Site</p>
          </div>
        </div>

        {projects && projects.map((project: any, index: number) => {
          // Mengatur variasi ukuran kolom bento secara selang-seling agar estetik
          const isEven = index % 2 === 0;
          return (
            <div class={`md:col-span-2 ${isEven ? 'md:row-span-2' : 'md:row-span-1'} bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden shadow-lg flex flex-col justify-between hover:border-zinc-700 transition-all duration-300 group`}>
              
              {/* Tempat Gambar jika Proyek Memiliki Thumbnail */}
              {project.imageUrl && isEven && (
                <div class="w-full h-48 overflow-hidden border-b border-zinc-800 bg-zinc-950 relative">
                  <img 
                    src={project.imageUrl} 
                    alt={project.title} 
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 opacity-80 group-hover:opacity-100"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-transparent to-transparent"></div>
                </div>
              )}

              <div class="p-6 flex-1 flex flex-col justify-between space-y-4">
                <div>
                  <div class="flex justify-between items-start mb-1">
                    <h3 class="font-bold text-xl text-zinc-100 tracking-tight group-hover:text-emerald-400 transition-colors">
                      {project.title}
                    </h3>
                    <span class="text-xs font-mono text-zinc-600">/{project.slug?.current}</span>
                  </div>
                  <p class="text-sm text-zinc-400 line-clamp-3 font-normal leading-relaxed">
                    {project.description || "Tidak ada deskripsi tambahan untuk studi kasus proyek ini."}
                  </p>
                </div>

                <div class="space-y-3">
                  {/* Render Tags teknologi */}
                  <div class="flex flex-wrap gap-1.5">
                    {project.tags?.map((tag: string) => (
                      <span class="px-2.5 py-0.5 bg-zinc-950 border border-zinc-800 rounded-md text-[11px] font-mono text-zinc-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                  
                  {/* Link Navigasi Proyek */}
                  <div class="flex gap-4 text-xs font-medium pt-2 border-t border-zinc-800/50">
                    {project.liveLink && (
                      <a href={project.liveLink} target="_blank" class="text-emerald-400 hover:underline">Live Demo ↗</a>
                    )}
                    {project.gitLink && (
                      <a href={project.gitLink} target="_blank" class="text-zinc-500 hover:text-zinc-300">Source Code</a>
                    )}
                  </div>
                </div>
              </div>

            </div>
          );
        })}

      </div>
    </main>
  </body>
</html>
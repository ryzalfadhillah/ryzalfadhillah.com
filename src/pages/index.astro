---
// src/pages/index.astro
import { client } from '../lib/sanity';
import '../styles/global.css';

// 🚀 FETCH DATA PROFIL LENGKAP DARI SANITY
const profile = await client.fetch(`
  *[_type == "profile"][0]{
    name,
    bio,
    githubUsername,
    "cvUrl": cvFile.asset->url,
    languages,
    certifications,
    experiences,
    education,
    socialLinks,
    contactEmail,
    contactHeading,
    contactDescription,
    skills,
    focusCompetency
  }
`);

// 🚀 FETCH DATA PROYEK FEATURED
const projects = await client.fetch(`
  *[_type == "project" && featured == true]{
    title,
    description,
    slug,
    tags,
    "imageUrl": thumbnail.asset->url,
    liveLink,
    gitLink
  }
`);

// 🚀 FETCH 2 ARTIKEL TERBARU
const latestArticles = await client.fetch(`
  *[_type == "article"] | order(_createdAt desc)[0..1]{
    title,
    slug,
    category,
    _createdAt
  }
`);

const DUMMY_IMAGE = "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800&auto=format&fit=crop";

// Pengolahan data teks berjalan (skills) dari Sanity
const techStack = profile?.skills && profile.skills.length > 0 
  ? profile.skills 
  : ['Astro Framework', 'React 19', 'Tailwind CSS v4', 'TypeScript', 'Node.js', 'GSAP Animation', 'Sanity CMS'];
const doubleTechStack = [...techStack, ...techStack];

// Menggandakan data proyek untuk efek Loop Spatial Marquee
const tripleProjects = projects ? [...projects, ...projects, ...projects] : [];
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile?.name || "Ryzal Fadhillah"} | Developer Hub</title>
    
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      if (theme === 'dark') document.documentElement.classList.add('dark');
      else document.documentElement.classList.remove('dark');
    </script>

    <style>
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .marquee-container {
        display: flex;
        width: max-content;
        animation: marquee 25s linear infinite;
      }
      .marquee-container:hover {
        animation-play-state: paused;
      }
    </style>
  </head>
  <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 font-sans min-h-screen transition-colors duration-300 selection:bg-emerald-500 selection:text-zinc-950">
    
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 space-y-16">
      
      <header class="flex justify-between items-center py-4 border-b border-zinc-200 dark:border-zinc-900">
        <span class="text-lg font-black tracking-tight bg-gradient-to-r from-emerald-500 to-teal-500 bg-clip-text text-transparent">
          {profile?.githubUsername ? `${profile.githubUsername}.com` : 'ryzalfadhillah.com'}
        </span>
        <nav class="flex items-center gap-6 text-sm font-medium">
          <a href="#" class="text-emerald-500 transition-colors">Beranda</a>
          <a href="/artikel" class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-200 transition-colors">Artikel</a>
          
          <button id="theme-toggle" class="p-2 rounded-xl bg-zinc-200/60 dark:bg-zinc-900 border border-zinc-300 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 hover:text-emerald-500 cursor-pointer transition-colors" aria-label="Toggle Theme">
            <svg id="theme-icon-sun" class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"/></svg>
            <svg id="theme-icon-moon" class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          </button>
        </nav>
      </header>

      <section class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        <div class="md:col-span-2 space-y-6">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-xs font-semibold animate-pulse">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Live Node Active
          </div>
          <h1 class="text-4xl sm:text-5xl font-black tracking-tight leading-tight text-zinc-900 dark:text-zinc-50">
            Halo, Saya {profile?.name || "Ryzal"}. <br/>
            <span class="bg-gradient-to-r from-zinc-800 via-zinc-500 to-zinc-400 dark:from-zinc-100 dark:via-zinc-400 dark:to-zinc-600 bg-clip-text text-transparent">
              Membangun Aplikasi Web Interaktif & Fleksibel.
            </span>
          </h1>
          <p class="text-zinc-600 dark:text-zinc-400 text-base sm:text-lg leading-relaxed max-w-2xl">
            {profile?.bio || "Data biografi belum terisi di Sanity Studio."}
          </p>
          <div class="flex flex-wrap gap-4 items-center pt-2">
            {profile?.cvUrl && (
              <a href={profile.cvUrl} target="_blank" class="px-5 py-2.5 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-bold text-sm rounded-xl transition-all shadow-lg shadow-emerald-500/10">
                Unduh Resume (PDF)
              </a>
            )}
            <div class="flex gap-4 text-sm text-zinc-400 dark:text-zinc-500 font-semibold">
              {profile?.socialLinks?.map((link: string) => (
                <a href={link} target="_blank" class="hover:text-emerald-500 transition-colors">
                  {link.includes('github') ? 'GitHub ↗' : link.includes('linkedin') ? 'LinkedIn ↗' : 'Tautan'}
                </a>
              ))}
            </div>
          </div>
        </div>
        
        <div id="hero-interactive-card" class="bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-3xl p-6 h-[260px] flex flex-col justify-between shadow-sm relative overflow-hidden group cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-teal-500/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="absolute w-full h-full opacity-5 dark:opacity-15 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:16px_16px]"></div>
            <div id="interactive-orb" class="w-28 h-28 rounded-full bg-gradient-to-tr from-emerald-400 to-cyan-500 opacity-20 dark:opacity-25 blur-xl transition-transform duration-300 ease-out"></div>
            <div class="absolute font-mono text-[11px] text-emerald-600 dark:text-emerald-400/50 bg-white dark:bg-zinc-950 px-2 py-1 rounded-md border border-zinc-200 dark:border-zinc-800 shadow-sm font-bold tracking-widest animate-pulse">&lt; CODE /&gt;</div>
          </div>
          <div class="relative z-10 flex justify-between items-start">
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500">Interactive Node</span>
            <span class="flex h-2 w-2 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
          </div>
          <div class="relative z-10">
            <p class="text-[11px] font-mono text-zinc-400 dark:text-zinc-500 group-hover:text-emerald-500 transition-colors">// Hover & drag kursor di sini</p>
            <h3 class="font-black text-base text-zinc-800 dark:text-zinc-100 mt-0.5">Creative Sandbox</h3>
          </div>
        </div>
      </section>

      <section class="space-y-10 pt-4">
        <div class="space-y-3">
          <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 px-1 flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-emerald-400 animate-ping"></span> Core Tech Weaponry
          </h2>
          <div class="w-full relative overflow-hidden py-4 bg-zinc-100/50 dark:bg-zinc-900/30 border-y border-zinc-200/80 dark:border-zinc-900/60 mask-gradient">
            <div class="absolute left-0 top-0 h-full w-16 bg-gradient-to-r from-zinc-50 dark:from-zinc-950 to-transparent z-10 pointer-events-none"></div>
            <div class="absolute right-0 top-0 h-full w-16 bg-gradient-to-l from-zinc-50 dark:from-zinc-950 to-transparent z-10 pointer-events-none"></div>
            <div class="marquee-container flex gap-8 items-center whitespace-nowrap">
              {doubleTechStack.map((tech) => (
                <div class="flex items-center gap-3 text-sm md:text-base font-bold tracking-tight text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors cursor-default">
                  <span>{tech}</span>
                  <span class="text-zinc-300 dark:text-zinc-800 font-normal select-none">•</span>
                </div>
              ))}
            </div>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-2 items-stretch">
          
          <div class="flex flex-col justify-between h-full space-y-8">
            
            <div class="space-y-4 shrink-0">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-b border-zinc-200 dark:border-zinc-900 pb-2">Linguistic Bandwidth</h3>
              <div class="space-y-4">
                {profile?.languages && profile.languages.length > 0 ? (
                  profile.languages.map((lang: any) => {
                    const isNative = lang.level?.toLowerCase().includes('native');
                    const barWidth = isNative ? 'w-full' : 'w-[80%]';
                    return (
                      <div class="space-y-1.5 group">
                        <div class="flex justify-between text-sm items-baseline">
                          <span class="font-extrabold text-zinc-800 dark:text-zinc-200 group-hover:text-emerald-400 transition-colors duration-300">{lang.language}</span>
                          <span class="text-[10px] font-mono text-zinc-400 uppercase tracking-wider">{lang.level}</span>
                        </div>
                        <div class="w-full h-[3px] bg-zinc-200 dark:bg-zinc-900 rounded-full overflow-hidden relative">
                          <div class={`h-full bg-gradient-to-r from-emerald-500 to-teal-400 rounded-full origin-left group-hover:scale-x-[1.03] transition-transform duration-500 ease-out ${barWidth}`}></div>
                          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] pointer-events-none"></div>
                        </div>
                      </div>
                    );
                  })
                ) : (
                  <p class="text-xs text-zinc-500 italic">Belum ada data bahasa.</p>
                )}
              </div>
            </div>

            <div class="space-y-3 flex-1 flex flex-col justify-center py-4">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 tracking-wider">Engine Cluster Allocation</h3>
              <div class="space-y-3 bg-zinc-100/40 dark:bg-zinc-900/10 border border-zinc-200/60 dark:border-zinc-900/40 p-4 rounded-2xl font-mono text-[11px] text-zinc-500">
                <div class="flex justify-between">
                  <span>[Vite v6 Core]: Active</span>
                  <span class="text-emerald-500">60 FPS</span>
                </div>
                <div class="w-full bg-zinc-200 dark:bg-zinc-900 h-1 rounded-full overflow-hidden">
                  <div class="bg-emerald-500 h-full w-[42%] animate-[pulse_2s_infinite]"></div>
                </div>
                <div class="flex justify-between pt-1">
                  <span>[Memory Stack]: Allocated</span>
                  <span class="text-teal-400">2026 MB</span>
                </div>
                <div class="w-full bg-zinc-200 dark:bg-zinc-900 h-1 rounded-full overflow-hidden">
                  <div class="bg-teal-400 h-full w-[68%] animate-[pulse_1.5s_infinite]"></div>
                </div>
              </div>
            </div>

            <div id="quantum-core-container" class="relative flex-1 rounded-2xl bg-zinc-100/40 border border-zinc-200/80 dark:bg-zinc-900/10 dark:border-zinc-900/60 overflow-hidden flex flex-col justify-between p-6 shadow-sm group/quantum min-h-[260px]">
              <canvas id="quantum-core-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0"></canvas>
              
              <div class="relative z-10 flex justify-between items-start pointer-events-none">
                <div class="flex items-center gap-2.5">
                  <span class="flex h-2 w-2 relative">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                  </span>
                  <span class="text-[10px] font-mono font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500">Neural Connectivity Cluster</span>
                </div>
                <span class="text-[9px] font-mono text-zinc-400 bg-white/70 dark:bg-zinc-950 px-2 py-0.5 rounded border border-zinc-200/60 dark:border-zinc-800">LIVE SYSTEM</span>
              </div>

              <div class="relative z-10 py-6 pointer-events-none">
                <h4 class="text-3xl font-mono font-black tracking-tight text-zinc-800 dark:text-zinc-50" id="live-digital-clock">00:00:00</h4>
                <p class="text-xs text-zinc-400 font-mono mt-1">Jakarta, ID — System Uptime Synchronized [2026]</p>
              </div>

              <div class="relative z-10 flex justify-between items-center pt-2 border-t border-zinc-200/60 dark:border-zinc-900/50">
                <span class="text-[10px] font-mono text-zinc-400/80 group-hover/quantum:text-emerald-500 transition-colors">// Hover to attract network / Click to trigger shockwave</span>
                <button id="ping-quantum-btn" class="px-4 py-1.5 rounded-xl bg-white text-zinc-700 border border-zinc-200 dark:bg-zinc-950 dark:text-zinc-400 dark:border-zinc-800 text-xs font-mono font-bold hover:text-emerald-500 hover:border-emerald-500/40 shadow-sm transition-all cursor-pointer">
                  TRIGGER_PULSE()
                </button>
              </div>
            </div>

          </div>

          <div class="space-y-4 relative flex flex-col">
            <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-b border-zinc-200 dark:border-zinc-900 pb-2">Engineering Domain</h3>
            
            <div id="ide-terminal-container" class="relative rounded-2xl bg-white text-zinc-700 border border-zinc-200 p-4 font-mono text-xs sm:text-sm shadow-2xl overflow-hidden group/ide select-none transition-all duration-300 will-change-transform flex-1 flex flex-col dark:bg-[#0d0e15] dark:text-zinc-400 dark:border-zinc-800" style="transform-style: preserve-3d;">
              <div class="flex items-center justify-between border-b border-zinc-200 pb-3 mb-4 shrink-0 dark:border-zinc-800/80">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-500/70"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-500/70"></span>
                </div>
                <span class="text-[10px] text-zinc-400 tracking-tight font-medium dark:text-zinc-600">domain_matrix.log</span>
                <span class="text-[10px] text-zinc-400 dark:text-zinc-700">UTF-8</span>
              </div>

              <div id="ide-glow-aura" class="absolute pointer-events-none w-48 h-48 rounded-full bg-emerald-500/5 blur-3xl opacity-0 group-hover/ide:opacity-100 transition-opacity duration-700" style="transform: translate(-50%, -50%);"></div>

              <div class="space-y-3 relative z-10 flex-1 overflow-y-auto pr-1" id="ide-lines-stack" style="transform: translateZ(30px);">
                {profile?.focusCompetency ? profile.focusCompetency.split('.').filter((s: string) => s.trim().length > 0).map((sentence: string, idx: number) => (
                  <div class="flex gap-4 ide-row-line opacity-25 transition-opacity duration-300 will-change-transform items-start">
                    <span class="text-zinc-400 dark:text-zinc-700 text-right select-none text-[11px] font-medium w-5 pt-0.5">0{idx + 1}</span>
                    <p class="text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed flex-1 tracking-wide">
                      <span class="text-emerald-500 font-bold">&gt;</span> {sentence.trim()}.
                    </p>
                  </div>
                )) : (
                  <p class="text-xs text-zinc-400 italic">No diagnostic logs found.</p>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-zinc-100 dark:bg-zinc-900/40 border border-zinc-200/80 dark:border-zinc-900 rounded-3xl p-6 flex flex-col justify-between overflow-hidden shadow-sm">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500">Grafik Kontribusi GitHub</h2>
          <span class="text-xs font-mono text-zinc-400">@{profile?.githubUsername || 'username'}</span>
        </div>
        <div class="w-full flex items-center justify-center pt-2 select-none dark:invert-0 invert dark:opacity-90">
          <img src={`https://ghchart.rshah.org/10b981/${profile?.githubUsername || 'ryzalfadhillah'}`} alt="Grafik Kontribusi GitHub" class="w-full h-auto object-contain" loading="lazy" />
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-l-2 border-emerald-500 pl-3">Sertifikasi & Training</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {profile?.certifications && profile.certifications.length > 0 ? (
            profile.certifications.map((cert: any) => (
              <div class="p-5 bg-zinc-100 dark:bg-zinc-900/50 border border-zinc-200/60 dark:border-zinc-900 rounded-2xl flex justify-between items-center group hover:border-zinc-300 dark:hover:border-zinc-800 transition-colors shadow-sm">
                <div>
                  <h3 class="font-bold text-sm text-zinc-800 dark:text-zinc-200 group-hover:text-emerald-500 transition-colors">{cert.title}</h3>
                  <p class="text-xs text-zinc-500 mt-0.5">{cert.issuer} • {cert.year}</p>
                </div>
              </div>
            ))
          ) : (
            <p class="text-xs text-zinc-500 italic col-span-2">Belum ada sertifikasi yang diinput di Sanity.</p>
          )}
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-4">
        <div class="space-y-6 relative">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-l-2 border-emerald-500 pl-3">Rekam Jejak & Pengalaman</h2>
          <div class="relative ml-3 pl-6 space-y-8 pt-2">
            <div class="timeline-line absolute left-0 top-0 bottom-0 w-[1px] bg-zinc-200 dark:bg-zinc-900 origin-top h-full"></div>
            
            {profile?.experiences && profile.experiences.length > 0 ? (
              profile.experiences.map((exp: any) => (
                <div class="relative group">
                  <div class="timeline-dot absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-zinc-50 dark:bg-zinc-950 border-2 border-zinc-300 dark:border-zinc-800 transition-colors duration-300 group-hover:border-emerald-500"></div>
                  <div class="space-y-1">
                    <span class="text-xs font-mono text-emerald-600 dark:text-emerald-400 font-semibold">{exp.period}</span>
                    <h3 class="font-bold text-base text-zinc-900 dark:text-zinc-100 group-hover:text-emerald-500 transition-colors">{exp.role}</h3>
                    <p class="text-xs text-zinc-500 dark:text-zinc-400 font-medium">{exp.company}</p>
                    <p class="text-xs text-zinc-500 dark:text-zinc-400 max-w-xl pt-1 whitespace-pre-line leading-relaxed">{exp.description}</p>
                  </div>
                </div>
              ))
            ) : (
              <p class="text-xs text-zinc-500 italic">Belum ada lini masa pengalaman kerja.</p>
            )}
          </div>
        </div>

        <div class="space-y-6 relative">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-l-2 border-teal-500 pl-3">Riwayat Pendidikan</h2>
          <div class="relative ml-3 pl-6 space-y-8 pt-2">
            <div class="timeline-line absolute left-0 top-0 bottom-0 w-[1px] bg-zinc-200 dark:bg-zinc-900 origin-top h-full"></div>

            {profile?.education && profile.education.length > 0 ? (
              profile.education.map((edu: any) => (
                <div class="relative group">
                  <div class="timeline-dot absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-zinc-50 dark:bg-zinc-950 border-2 border-zinc-300 dark:border-zinc-800 transition-colors duration-300 group-hover:border-teal-500"></div>
                  <div class="space-y-1">
                    <span class="text-xs font-mono text-teal-600 dark:text-teal-400 font-semibold">{edu.period}</span>
                    <h3 class="font-bold text-base text-zinc-900 dark:text-zinc-100 group-hover:text-teal-500 transition-colors">{edu.degree}</h3>
                    <p class="text-xs text-zinc-500 dark:text-zinc-400 font-medium">{edu.institution}</p>
                    {edu.description && <p class="text-xs text-zinc-500 dark:text-zinc-400 max-w-xl pt-1 whitespace-pre-line leading-relaxed">{edu.description}</p>}
                  </div>
                </div>
              ))
            ) : (
              <p class="text-xs text-zinc-500 italic">Belum ada lini masa riwayat pendidikan.</p>
            )}
          </div>
        </div>
      </section>

      <section class="space-y-4" id="spatial-marquee-section">
        <div class="flex justify-between items-baseline px-1">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-l-2 border-emerald-500 pl-3">
            Proyek Pilihan (Spatial Lens Loop)
          </h2>
          <span class="text-[10px] font-mono text-zinc-400 dark:text-zinc-50">// Hover untuk Berhenti & Fokus</span>
        </div>

        <div class="w-full relative overflow-hidden py-8 bg-zinc-100/30 dark:bg-zinc-900/10 border border-zinc-200 dark:border-zinc-900 rounded-3xl" style="perspective: 1200px;">
          <div id="lens-marquee-track" class="flex gap-8 items-center whitespace-nowrap will-change-transform py-4" style="transform-style: preserve-3d; width: max-content;">
            {tripleProjects.map((project: any) => {
              const projectImage = project.imageUrl || DUMMY_IMAGE;
              return (
                <div 
                  class="lens-project-card w-[280px] sm:w-[360px] h-[380px] sm:h-[440px] bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800/80 rounded-[28px] overflow-hidden flex flex-col justify-between shadow-xl inline-block whitespace-normal select-none will-change-transform transition-[filter] duration-300"
                  style="transform-style: preserve-3d;"
                >
                  <div class="w-full h-[45%] overflow-hidden relative bg-zinc-950">
                    <img src={projectImage} alt={project.title} class="w-full h-full object-cover opacity-85" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-white dark:from-zinc-900 to-transparent opacity-90"></div>
                  </div>

                  <div class="p-6 flex-1 flex flex-col justify-between space-y-4">
                    <div class="space-y-1">
                      <h3 class="font-black text-lg text-zinc-900 dark:text-zinc-50 tracking-tight leading-none">{project.title}</h3>
                      <p class="text-[10px] font-mono text-zinc-400">/{project.slug?.current}</p>
                      <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 pt-1">{project.description || "Studi kasus implementasi sistem headless."}</p>
                    </div>

                    <div class="space-y-3 pt-2 border-t border-zinc-100 dark:border-zinc-800/60">
                      <div class="flex flex-wrap gap-1">
                        {project.tags?.slice(0, 3).map((tag: string) => (
                          <span class="px-2 py-0.5 bg-zinc-100 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 text-[9px] font-mono rounded text-zinc-400">{tag}</span>
                        ))}
                      </div>
                      <div class="flex gap-4 text-xs font-bold">
                        {project.liveLink && <a href={project.liveLink} target="_blank" class="text-emerald-600 dark:text-emerald-400 hover:underline">Demo ↗</a>}
                        {project.gitLink && <a href={project.gitLink} target="_blank" class="text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200">Source</a>}
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          
          <div class="absolute left-0 top-0 h-full w-12 bg-gradient-to-r from-zinc-50/80 dark:from-zinc-950/80 to-transparent pointer-events-none z-20 rounded-l-3xl"></div>
          <div class="absolute right-0 top-0 h-full w-12 bg-gradient-to-l from-zinc-50/80 dark:from-zinc-950/80 to-transparent pointer-events-none z-20 rounded-r-3xl"></div>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 border-l-2 border-emerald-500 pl-3">Artikel & Catatan Terbaru</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {latestArticles && latestArticles.length > 0 ? (
            latestArticles.map((article: any) => (
              <a href={`/artikel/${article.slug?.current}`} class="article-card p-5 bg-zinc-100 dark:bg-zinc-900/50 border border-zinc-200/60 dark:border-zinc-900 rounded-2xl block group hover:border-emerald-500/50 dark:hover:border-emerald-500/50 transition-all shadow-sm">
                <div class="flex justify-between items-start mb-2">
                  <span class="px-2 py-0.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 text-[10px] font-mono rounded font-medium text-emerald-600 dark:text-emerald-400">{article.category || "General"}</span>
                  <span class="text-[10px] font-mono text-zinc-400">{new Date(article._createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'short' })}</span>
                </div>
                <h3 class="font-bold text-sm sm:text-base text-zinc-800 dark:text-zinc-200 group-hover:text-emerald-500 transition-colors line-clamp-1">{article.title}</h3>
                
                <span class="text-xs text-emerald-600 dark:text-emerald-400 font-medium inline-block mt-2">
                  Baca Tulisan <span class="article-arrow inline-block transition-transform select-none">→</span>
                </span>
              </a>
            ))
          ) : (
            <p class="text-sm italic text-zinc-400">Belum ada artikel yang di-publish.</p>
          )}
        </div>
      </section>

      <section id="kontak" class="bg-zinc-100 dark:bg-zinc-900/50 border border-zinc-200/60 dark:border-zinc-900 rounded-3xl p-8 sm:p-10 grid grid-cols-1 md:grid-cols-3 gap-6 items-center shadow-sm">
        <div class="md:col-span-2 space-y-2">
          <h2 class="text-2xl font-black text-zinc-900 dark:text-zinc-50 tracking-tight">
            {profile?.contactHeading || "Mari Berkolaborasi!"}
          </h2>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-md">
            {profile?.contactDescription || "Pintu komunikasi saya selalu terbuka untuk mendiskusikan rekayasa perangkat lunak harian."}
          </p>
        </div>
        <div class="md:text-right">
          <a 
            id="email-magnetic-btn"
            href={`mailto:${profile?.contactEmail || 'contact@ryzalfadhillah.com'}`} 
            class="inline-block px-6 py-3 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 hover:border-emerald-500 hover:text-emerald-600 dark:hover:text-emerald-400 font-extrabold text-sm rounded-xl shadow-md transition-colors cursor-pointer will-change-transform select-none"
          >
            Kirim Email Kerja
          </a>
        </div>
      </section>

      <footer class="pt-4 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-zinc-400 dark:text-zinc-600">
        <p>© 2026 {profile?.name || "Ryzal Fadhillah"}. Dipersembahkan secara murni dengan Astro & Sanity.</p>
        <a href="#" class="hover:underline">Kembali ke Atas ↑</a>
      </footer>

    </div>

    <script>
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const documentElement = document.documentElement;
        documentElement.classList.toggle('dark');
        const isDark = documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        window.dispatchEvent(new Event('theme-changed'));
      });
    </script>

    <script>
      const card = document.getElementById('hero-interactive-card');
      const orb = document.getElementById('interactive-orb');
      card?.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        if (orb) orb.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px) scale(1.15)`;
      });
      card?.addEventListener('mouseleave', () => {
        if (orb) orb.style.transform = `translate(0px, 0px) scale(1)`;
      });
    </script>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const track = document.getElementById('lens-marquee-track');
      const cards = document.querySelectorAll('.lens-project-card');

      if (track && cards.length > 0) {
        const trackWidth = track.scrollWidth / 3;
        
        const marqueeTween = gsap.to(track, {
          x: -trackWidth,
          ease: "none",
          duration: 22,
          repeat: -1,
          runBackwards: false
        });

        track.addEventListener('mouseenter', () => marqueeTween.pause());
        track.addEventListener('mouseleave', () => marqueeTween.play());

        function calculateSpatialLens() {
          const viewportCenter = window.innerWidth / 2;

          cards.forEach((card) => {
            const cardRect = card.getBoundingClientRect();
            const cardCenter = cardRect.left + cardRect.width / 2;
            
            const distanceRatio = (cardCenter - viewportCenter) / (window.innerWidth / 2);
            const absRatio = Math.abs(distanceRatio);

            if (absRatio < 1.5) {
              const scale = 1 - (absRatio * 0.14);
              const opacity = 1 - (absRatio * 0.45);
              const rotateY = distanceRatio * -24;
              const translateZ = absRatio * -120;
              const blurValue = Math.max(0, (absRatio - 0.2) * 5);

              gsap.set(card, {
                scale: scale,
                opacity: opacity,
                rotationY: rotateY,
                z: translateZ,
                transformPerspective: 1000,
                filter: `blur(${blurValue}px)`,
                overwrite: "auto"
              });
            }
          });
        }

        gsap.ticker.add(calculateSpatialLens);
      }

      // ✨ BACKEND ENGINE: LOG BARIS IDE TERMINAL REVEAL SCROLL & 3D INTERACTIVE TILT + NEON HOVER GLOW
      const ideContainer = document.getElementById('ide-terminal-container');
      const ideTorch = document.getElementById('ide-glow-aura');
      const ideRows = document.querySelectorAll('.ide-row-line');

      if (ideContainer && ideRows.length > 0) {
        gsap.to(ideRows, {
          scrollTrigger: {
            trigger: ideContainer,
            start: "top 85%",
            end: "bottom 65%",
            scrub: 0.5,
          },
          opacity: 1,
          stagger: 0.2,
          ease: "power2.out"
        });

        ideContainer.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = ideContainer.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;

          const xTilt = (x - rect.width / 2) / (rect.width / 2);
          const yTilt = (y - rect.height / 2) / (rect.height / 2);

          const isDark = document.documentElement.classList.contains('dark');
          const glowColor = isDark ? "rgba(16, 185, 129, 0.22)" : "rgba(5, 150, 105, 0.12)";
          const borderColor = isDark ? "rgba(16, 185, 129, 0.3)" : "rgba(5, 150, 105, 0.4)";

          gsap.to(ideContainer, {
            rotationY: xTilt * 8,
            rotationX: -yTilt * 8,
            transformPerspective: 1200,
            boxShadow: `0 0 35px 5px ${glowColor}, 0 25px 50px -12px rgba(0, 0, 0, 0.15)`,
            borderColor: borderColor,
            duration: 0.3,
            ease: "power2.out"
          });

          if (ideTorch) {
            gsap.to(ideTorch, {
              left: `${x}px`,
              top: `${y}px`,
              duration: 0.2,
              ease: "power2.out"
            });
          }
        });

        ideContainer.addEventListener('mouseleave', () => {
          const isDark = document.documentElement.classList.contains('dark');
          const defaultBorder = isDark ? "rgb(39, 39, 42)" : "rgb(228, 228, 231)";

          gsap.to(ideContainer, {
            rotationY: 0,
            rotationX: 0,
            boxShadow: isDark ? "0 25px 50px -12px rgba(0, 0, 0, 0.5)" : "0 10px 30px -10px rgba(0,0,0,0.08)",
            borderColor: defaultBorder,
            duration: 0.6,
            ease: "power2.out"
          });
        });
      }

      // 🌟 QUANTUM ENGINE: HTML5 CANVAS PARTICLE SIMULATION
      const quantumContainer = document.getElementById('quantum-core-container');
      const canvas = document.getElementById('quantum-core-canvas') as HTMLCanvasElement;
      const clockElement = document.getElementById('live-digital-clock');
      const pingBtn = document.getElementById('ping-quantum-btn');

      if (canvas && quantumContainer) {
        const ctx = canvas.getContext('2d')!;
        let particles: any[] = [];
        let mouse = { x: -1000, y: -1000, active: false };
        let shockwaveRadius = 0;
        let shockwaveX = 0;
        let shockwaveY = 0;

        function resizeCanvas() {
          canvas.width = quantumContainer.clientWidth;
          canvas.height = quantumContainer.clientHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        class Particle {
          x: number; y: number; vx: number; vy: number; baseSize: number;
          constructor() {
            this.x = Math.random() * canvas.width;
            this.y = Math.random() * canvas.height;
            this.vx = (Math.random() - 0.5) * 0.6;
            this.vy = (Math.random() - 0.5) * 0.6;
            this.baseSize = Math.random() * 1.5 + 1;
          }
          update() {
            this.x += this.vx;
            this.y += this.vy;

            if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
            if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

            if (mouse.active) {
              const dx = mouse.x - this.x;
              const dy = mouse.y - this.y;
              const dist = Math.hypot(dx, dy);
              if (dist < 100) {
                this.x += (dx / dist) * 0.8;
                this.y += (dy / dist) * 0.8;
              }
            }

            if (shockwaveRadius > 0) {
              const dx = this.x - shockwaveX;
              const dy = this.y - shockwaveY;
              const dist = Math.hypot(dx, dy);
              if (Math.abs(dist - shockwaveRadius) < 15) {
                this.x += (dx / dist) * 8;
                this.y += (dy / dist) * 8;
              }
            }
          }
          draw(color: string) {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.baseSize, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
          }
        }

        for (let i = 0; i < 45; i++) particles.push(new Particle());

        function renderQuantumLoop() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          const isDark = document.documentElement.classList.contains('dark');
          const nodeColor = isDark ? 'rgba(16, 185, 129, 0.45)' : 'rgba(5, 150, 105, 0.35)';
          const lineColor = isDark ? 'rgba(16, 185, 129, 0.06)' : 'rgba(5, 150, 105, 0.05)';

          if (shockwaveRadius > 0) {
            shockwaveRadius += 6;
            if (shockwaveRadius > canvas.width * 1.2) shockwaveRadius = 0;
            ctx.beginPath();
            ctx.arc(shockwaveX, shockwaveY, shockwaveRadius, 0, Math.PI * 2);
            ctx.strokeStyle = isDark ? `rgba(16, 185, 129, ${1 - (shockwaveRadius/(canvas.width*1.2))})` : `rgba(5, 150, 105, ${1 - (shockwaveRadius/(canvas.width*1.2))})`;
            ctx.lineWidth = 1.5;
            ctx.stroke();
          }

          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dist = Math.hypot(particles[i].x - particles[j].x, particles[i].y - particles[j].y);
              if (dist < 75) {
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = lineColor;
                ctx.lineWidth = 0.8;
                ctx.stroke();
              }
            }
            particles[i].update();
            particles[i].draw(nodeColor);
          }
          requestAnimationFrame(renderQuantumLoop);
        }
        requestAnimationFrame(renderQuantumLoop);

        quantumContainer.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = quantumContainer.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
          mouse.active = true;
        });
        quantumContainer.addEventListener('mouseleave', () => { mouse.active = false; });

        function triggerShockwave(x: number, y: number) {
          shockwaveX = x;
          shockwaveY = y;
          shockwaveRadius = 1;
        }

        quantumContainer.addEventListener('click', (e: MouseEvent) => {
          const rect = quantumContainer.getBoundingClientRect();
          triggerShockwave(e.clientX - rect.left, e.clientY - rect.top);
        });

        pingBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          triggerShockwave(canvas.width / 2, canvas.height / 2);
        });

        window.addEventListener('theme-changed', () => {
          particles.forEach(p => {
            p.vx = (Math.random() - 0.5) * 1.5;
            p.vy = (Math.random() - 0.5) * 1.5;
          });
        });
      }

      if (clockElement) {
        setInterval(() => {
          const now = new Date();
          now.setFullYear(2026);
          clockElement.innerText = now.toLocaleTimeString('id-ID', { hour12: false });
        }, 1000);
      }

      // ==========================================
      // 🔥 NEW SUNTIKAN INTEGRASI KETIGA ANIMASI MIKRO PREMIUM
      // ==========================================

      // 🧱 POLE 1: Scroll-Driven Timeline Drawing Engine
      const lines = document.querySelectorAll('.timeline-line');
      const dots = document.querySelectorAll('.timeline-dot');

      lines.forEach(line => {
        gsap.fromTo(line, 
          { scaleY: 0 }, 
          {
            scaleY: 1,
            ease: "none",
            scrollTrigger: {
              trigger: line,
              start: "top 75%",
              end: "bottom 65%",
              scrub: true
            }
          }
        );
      });

      dots.forEach(dot => {
        gsap.fromTo(dot,
          { scale: 0, opacity: 0 },
          {
            scale: 1,
            opacity: 1,
            ease: "back.out(1.8)",
            scrollTrigger: {
              trigger: dot,
              start: "top 72%",
              toggleActions: "play none none reverse"
            }
          }
        );
      });

      // 🧱 POLE 2: High-End Spatial Magnetic CTA Button Engine
      const magneticBtn = document.getElementById('email-magnetic-btn');
      
      if (magneticBtn) {
        magneticBtn.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = magneticBtn.getBoundingClientRect();
          // Hitung jarak kursor dari titik tengah tombol
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;

          // Sedot tombol mendekati kursor secara magnetis (redaman 35%)
          gsap.to(magneticBtn, {
            x: x * 0.35,
            y: y * 0.35,
            scale: 1.02,
            duration: 0.2,
            ease: "power2.out"
          });
        });

        magneticBtn.addEventListener('mouseleave', () => {
          // Efek membal elastis / karet saat kursor dilepas mendadak
          gsap.to(magneticBtn, {
            x: 0,
            y: 0,
            scale: 1,
            duration: 0.6,
            ease: "elastic.out(1, 0.35)"
          });
        });
      }

      // 🧱 POLE 3: Asymmetrical Article Link Spring Bounce Arrow Engine
      const articleCards = document.querySelectorAll('.article-card');
      
      articleCards.forEach(card => {
        const arrow = card.querySelector('.article-arrow');
        
        card.addEventListener('mouseenter', () => {
          if (arrow) {
            // Animasi memantul pegas tanpa putus saat hover kartu
            gsap.to(arrow, {
              x: 5,
              duration: 0.4,
              ease: "power1.inOut",
              repeat: -1,
              yoyo: true
            });
          }
        });

        card.addEventListener('mouseleave', () => {
          if (arrow) {
            // Pulangkan panah ke titik koordinat 0 semula dengan halus
            gsap.to(arrow, {
              x: 0,
              duration: 0.3,
              ease: "power2.out",
              overwrite: "auto"
            });
          }
        });
      });
    </script>
  </body>
</html>
---
// src/pages/proyek/[slug].astro
import { client } from '../../lib/sanity';
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';

import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';

// 🚀 1. DEFINISIKAN SEMUA RUTE DINAMIS
export async function getStaticPaths() {
  const projects = await client.fetch(`*[_type == "project" && defined(slug.current)]`);
  return projects.map((project: any) => ({
    params: { slug: project.slug.current },
  }));
}

const { slug } = Astro.params;

// 🚀 2. PIPELINE DATA SANITY
const project = await client.fetch(`
  *[_type == "project" && slug.current == $slug][0]{
    title,
    description,
    tags,
    "imageUrl": thumbnail.asset->url,
    liveLink,
    gitLink,
    content
  }
`, { slug });

const tracks = await client.fetch(`*[_type == "track"]{ trackTitle, artist, youtubeUrl }`);
const profile = await client.fetch(`*[_type == "profile"][0]{ name }`);

const renderContent = (contentArray: any) => {
  if (!contentArray || contentArray.length === 0) return null;
  return contentArray.map((block: any) => {
    if (block._type === 'block') {
      const text = block.children?.map((c: any) => c.text).join('') || '';
      if (block.style === 'h2') return `<h2 class="text-xl font-bold text-zinc-800 dark:text-zinc-100 mt-8 mb-3 border-b border-zinc-100 dark:border-zinc-900 pb-2 font-mono">// ${text}</h2>`;
      if (block.style === 'h3') return `<h3 class="text-lg font-bold text-zinc-800 dark:text-zinc-100 mt-6 mb-2">${text}</h3>`;
      return `<p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-4 text-sm sm:text-base">${text}</p>`;
    }
    return '';
  }).join('');
};
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project?.title || "Detail Proyek"} | Case Study</title>
    <script is:inline>
      const applyThemeEngine = () => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        if (theme === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      };
      applyThemeEngine();
      document.addEventListener('astro:after-swap', applyThemeEngine);
    </script>
    <ClientRouter />
  </head>
  <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 font-sans min-h-screen transition-colors duration-300">
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 space-y-10">
      <Header />
      
      <AudioPlayer tracks={tracks} transition:persist="cyber-audio" />
      
      <div class="pt-2">
        <a id="back-to-projects-btn" href="/proyek" class="inline-flex items-center gap-2 text-xs font-mono font-bold text-zinc-400 hover:text-emerald-500 border border-zinc-200 dark:border-zinc-900 bg-white dark:bg-zinc-950 px-4 py-2 rounded-xl transition-colors shadow-sm cursor-pointer select-none">
          ← KEMBALI KE GALERI
        </a>
      </div>

      <main class="space-y-8 opacity-0 transform translate-y-6" id="main-project-case-study">
        
        <header class="space-y-4 border-b border-zinc-200/80 dark:border-zinc-900 pb-6">
          <div class="flex flex-wrap items-center gap-2 text-xs font-mono font-bold uppercase tracking-wider text-zinc-400">
            <span class="text-emerald-500">// Case Study Architecture</span>
          </div>
          <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-tight text-zinc-900 dark:text-zinc-50">
            {project?.title}
          </h1>
          
          <div class="flex flex-wrap gap-1.5 pt-1">
            {project?.tags?.map((tag: string) => (
              <span class="text-[10px] font-mono font-bold px-2.5 py-1 rounded-lg bg-zinc-100 text-zinc-600 dark:bg-zinc-900 dark:text-emerald-400 border border-zinc-200/40 dark:border-zinc-800/40">{tag}</span>
            ))}
          </div>
        </header>

        {project?.imageUrl && (
          <div id="project-hero-cover-wrap" class="w-full h-[220px] sm:h-[380px] rounded-3xl overflow-hidden bg-zinc-900 shadow-xl select-none relative will-change-transform">
            <img src={project.imageUrl} alt={project.title} id="project-hero-img" class="w-full h-full object-cover opacity-85 scale-105 will-change-transform" />
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-2">
          
          <div class="md:col-span-2 space-y-6">
            <div class="space-y-4">
              <h2 class="text-xl font-bold tracking-tight text-zinc-800 dark:text-zinc-50 font-mono">// Ikhtisar Proyek</h2>
              <p class="text-sm sm:text-base text-zinc-500 dark:text-zinc-400 leading-relaxed whitespace-pre-line font-medium">
                {project?.description || "Tidak ada ikhtisar tambahan untuk cetak biru sistem teknologi ini."}
              </p>
            </div>

            {project?.content && (
              <div class="prose max-w-none pt-2 text-zinc-800 dark:text-zinc-200" set:html={renderContent(project.content)}></div>
            )}
          </div>

          <div class="space-y-4">
            <div class="p-5 rounded-2xl bg-zinc-100/40 dark:bg-zinc-900/10 border border-zinc-200 dark:border-zinc-900/60 space-y-4">
              <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-400">// Deployment Links</h3>
              
              <div class="flex flex-col gap-2">
                {project?.liveLink ? (
                  <a 
                    href={project.liveLink} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="project-action-btn flex items-center justify-center gap-1.5 w-full py-2.5 text-xs font-mono font-bold uppercase bg-emerald-500 text-zinc-950 hover:bg-emerald-400 rounded-xl transition-all shadow-md shadow-emerald-500/5 cursor-pointer text-center"
                  >
                    Buka Aplikasi Live ↗
                  </a>
                ) : (
                  <button 
                    disabled
                    class="flex items-center justify-center gap-1.5 w-full py-2.5 text-xs font-mono font-bold uppercase bg-zinc-200/50 text-zinc-400 dark:bg-zinc-900 dark:text-zinc-600 border border-zinc-200/60 dark:border-zinc-800/40 rounded-xl cursor-not-allowed text-center select-none"
                  >
                    Live App Belum Tersedia
                  </button>
                )}
                
                {project?.gitLink && (
                  <a 
                    href={project.gitLink} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="project-action-btn flex items-center justify-center w-full py-2.5 text-xs font-mono font-bold uppercase bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-600 dark:text-zinc-400 hover:border-emerald-500/40 hover:text-emerald-500 rounded-xl transition-all shadow-sm cursor-pointer text-center"
                  >
                    Source Code GitHub
                  </a>
                )}
              </div>
            </div>
          </div>

        </div>

      </main>

      <Footer name={profile?.name} />
    </div>

  </body>
</html>

<script>
  import { gsap } from 'gsap';

  function initProjectDetailCaseEngine() {
    const caseStudyContainer = document.getElementById('main-project-case-study');
    const backBtn = document.getElementById('back-to-projects-btn');
    const actionBtns = document.querySelectorAll('.project-action-btn');
    const coverWrap = document.getElementById('project-hero-cover-wrap');
    const coverImg = document.getElementById('project-hero-img');

    if (caseStudyContainer) {
      gsap.to(caseStudyContainer, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" });
    }

    if (coverWrap && coverImg) {
      gsap.killTweensOf([coverWrap, coverImg]);
      gsap.fromTo(coverWrap, {
        clipPath: 'inset(12% 12% 12% 12% rounded 24px)'
      }, {
        clipPath: 'inset(0% 0% 0% 0% rounded 24px)',
        duration: 1.1,
        ease: "power4.out",
        delay: 0.1
      });
      gsap.fromTo(coverImg, { scale: 1.12 }, { scale: 1, duration: 1.3, ease: "power3.out", delay: 0.1 });
    }

    // Efek magnetik hanya akan mengikat tombol aktif berkelas .project-action-btn
    const interactiveElements = [backBtn, ...Array.from(actionBtns)];
    interactiveElements.forEach((btn: any) => {
      if (!btn) return;
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        gsap.to(btn, { 
          x: (e.clientX - rect.left - rect.width/2) * 0.35, 
          y: (e.clientY - rect.top - rect.height/2) * 0.35, 
          scale: 1.02, 
          duration: 0.2 
        });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, scale: 1, duration: 0.6, ease: "elastic.out(1, 0.35)" });
      });
    });
  }

  document.addEventListener('astro:page-load', initProjectDetailCaseEngine);
</script>